---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  const categories = [
    { name: 'Dharma Writings',           slug: 'dharma-writings' },
    { name: 'Creative Writing',           slug: 'creative-writing' },
    { name: 'Consciousness & Philosophy', slug: 'consciousness-philosophy' },
    { name: 'Practice & Inner Life',      slug: 'practice-inner-life' },
    { name: 'Other',                       slug: 'other' }
  ];

  return categories.map(category => {
    const categoryPosts = allPosts
      .filter(post => post.data.categories.includes(category.name))
      .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

    return {
      params: { category: category.slug },
      props: { categoryName: category.name, posts: categoryPosts }
    };
  });
}

const { categoryName, posts } = Astro.props;

const descriptions: Record<string, string> = {
  'Dharma Writings':            'Explorations of Buddhist teachings, philosophy, and the path',
  'Creative Writing':            'Fiction, poetry, and imaginative works',
  'Consciousness & Philosophy':  'Reflections on mind, reality, and the nature of existence',
  'Practice & Inner Life':       'Meditation, dreams, and spiritual practices',
  'Other':                        'Various topics and musings'
};

const slugOf = (p: any) => p.data.slug ?? p.slug;

const themeIdsBySlug: Record<string, string[]> = {};
for (const p of posts) {
  const s = slugOf(p);
  try {
    const sc = await import(`../../content/themes/${s}.json`);
    themeIdsBySlug[s] = sc.default.themeIds ?? [];
  } catch {
    themeIdsBySlug[s] = [];
  }
}
---

<Layout title={`${categoryName} — Hologram Thoughts`} description={descriptions[categoryName] ?? `Posts in ${categoryName}.`}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-2">
      <a href="/categories" class="no-underline hover:text-[var(--color-cyan)]">Categories</a> · {posts.length} posts
    </p>
    <h1 class="text-5xl tracking-tight" style="font-family: var(--font-display);">{categoryName}</h1>
    <p class="text-[var(--color-ink-soft)] mt-3 italic">{descriptions[categoryName]}</p>
  </header>

  <section class="space-y-2">
    {posts.map((post: any) => {
      const s = slugOf(post);
      return (
        <PostCard
          slug={s}
          title={post.data.title}
          pubDate={post.data.pubDate}
          themeIds={themeIdsBySlug[s]}
        />
      );
    })}
  </section>
</Layout>
