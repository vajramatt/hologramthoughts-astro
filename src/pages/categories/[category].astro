---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  const categories = [
    { name: 'Dharma Writings',           slug: 'dharma-writings' },
    { name: 'Creative Writing',           slug: 'creative-writing' },
    { name: 'Consciousness & Philosophy', slug: 'consciousness-philosophy' },
    { name: 'Practice & Inner Life',      slug: 'practice-inner-life' },
    { name: 'Other',                       slug: 'other' }
  ];

  return categories.map(category => {
    const categoryPosts = allPosts
      .filter(post => post.data.categories.includes(category.name))
      .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

    return {
      params: { category: category.slug },
      props: { categoryName: category.name, posts: categoryPosts }
    };
  });
}

const { categoryName, posts } = Astro.props;

const descriptions = {
  'Dharma Writings':            'Buddhist teachings, philosophy, the path.',
  'Creative Writing':            'Fiction, poetry, imagined worlds.',
  'Consciousness & Philosophy':  'Mind, reality, the nature of being.',
  'Practice & Inner Life':       'Meditation, dreams, devotional practice.',
  'Other':                        'Everything else worth saying.'
};

const formatDate = (d) => d.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: '2-digit'
});
---

<Layout title={`${categoryName} — Hologram Thoughts`}>
  <div class="page">
    <SiteHeader activePage="categories" />

    <main class="page-main category">
      <header class="page-header">
        <p class="eyebrow">
          <a href="/categories">Categories</a>
        </p>
        <h1>{categoryName}</h1>
        <p class="page-dek">{descriptions[categoryName]}</p>
        <p class="page-count">{posts.length} piece{posts.length === 1 ? '' : 's'}</p>
      </header>

      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/blog/${post.slug}`} class="post-link">
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              <div class="post-body">
                <span class="post-title">{post.data.title}</span>
                {post.data.description && (
                  <span class="post-excerpt">{post.data.description}</span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .category {
    max-width: var(--measure);
    margin: 0 auto;
  }

  .page-header {
    margin: 1rem 0 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .eyebrow a {
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .eyebrow a:hover { color: var(--accent); }

  .page-header h1 {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "SOFT" 40;
    font-weight: 500;
    font-size: clamp(1.85rem, 1.4rem + 1.8vw, 2.65rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
    color: var(--fg-bright);
  }

  .page-dek {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--fg-dim);
    margin: 0 0 0.5rem;
  }

  .page-count {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
  }

  .post-list li + li {
    border-top: 1px solid var(--rule);
  }

  .post-link {
    display: flex;
    gap: 1.25rem;
    padding: 1rem 0;
    text-decoration: none;
    color: inherit;
    align-items: baseline;
  }

  .post-date {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 6rem;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .post-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 40;
    font-weight: 500;
    font-size: 1.1rem;
    line-height: 1.3;
    color: var(--fg-bright);
    text-wrap: balance;
    transition: color 150ms ease;
  }

  .post-link:hover .post-title { color: var(--accent); }

  .post-excerpt {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--fg-dim);
    line-height: 1.5;
    text-wrap: pretty;
  }

  @media (max-width: 36rem) {
    .post-link { gap: 1rem; }
    .post-date { min-width: 4.5rem; font-size: 0.75rem; }
    .post-title { font-size: 1rem; }
  }
</style>
