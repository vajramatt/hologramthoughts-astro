---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categories = [
  { name: 'Dharma Writings',            description: 'Explorations of Buddhist teachings, philosophy, and the path', slug: 'dharma-writings' },
  { name: 'Creative Writing',            description: 'Fiction, poetry, and imaginative works', slug: 'creative-writing' },
  { name: 'Consciousness & Philosophy',  description: 'Reflections on mind, reality, and the nature of existence', slug: 'consciousness-philosophy' },
  { name: 'Practice & Inner Life',       description: 'Meditation, dreams, and spiritual practices', slug: 'practice-inner-life' },
  { name: 'Other',                        description: 'Various topics and musings', slug: 'other' },
];

const categoryCounts: Record<string, number> = {};
allPosts.forEach(post => {
  post.data.categories.forEach(category => {
    categoryCounts[category] = (categoryCounts[category] || 0) + 1;
  });
});

const categoriesWithCounts = categories.map(cat => ({
  ...cat,
  count: categoryCounts[cat.name] || 0
}));
---

<Layout title="Categories — Hologram Thoughts">
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-2">Browse</p>
    <h1 class="text-5xl tracking-tight" style="font-family: var(--font-display);">Categories</h1>
    <p class="text-[var(--color-ink-soft)] mt-3 max-w-xl">
      Five broad gardens for twenty years of writing.
    </p>
  </header>

  <ul class="space-y-6">
    {categoriesWithCounts.map(category => (
      <li class="border-b border-[var(--color-border-strong)] pb-6">
        <a href={`/categories/${category.slug}`} class="block group no-underline">
          <div class="flex items-baseline justify-between gap-4">
            <h2 class="text-2xl group-hover:text-[var(--color-bioluminescent)] transition-colors" style="font-family: var(--font-display);">{category.name}</h2>
            <span class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{category.count} posts</span>
          </div>
          <p class="text-[var(--color-ink-soft)] mt-2 italic">{category.description}</p>
        </a>
      </li>
    ))}
  </ul>
</Layout>
