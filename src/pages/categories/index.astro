---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categories = [
  { name: 'Dharma Writings',           description: 'Buddhist teachings, philosophy, the path.',                 slug: 'dharma-writings' },
  { name: 'Creative Writing',           description: 'Fiction, poetry, imagined worlds.',                          slug: 'creative-writing' },
  { name: 'Consciousness & Philosophy', description: 'Mind, reality, the nature of being.',                        slug: 'consciousness-philosophy' },
  { name: 'Practice & Inner Life',      description: 'Meditation, dreams, devotional practice.',                   slug: 'practice-inner-life' },
  { name: 'Other',                       description: 'Everything else worth saying.',                              slug: 'other' },
];

const categoryCounts = {};
allPosts.forEach(post => {
  post.data.categories.forEach(category => {
    categoryCounts[category] = (categoryCounts[category] || 0) + 1;
  });
});

const categoriesWithCounts = categories
  .map(cat => ({ ...cat, count: categoryCounts[cat.name] || 0 }))
  .filter(cat => cat.count > 0);
---

<Layout title="Categories — Hologram Thoughts">
  <div class="page">
    <SiteHeader activePage="categories" />

    <main class="page-main categories">
      <header class="page-header">
        <p class="eyebrow">Categories</p>
        <h1>Five ways in.</h1>
        <p class="page-dek">Same writing, grouped differently depending on what brought you here.</p>
      </header>

      <ul class="cat-list">
        {categoriesWithCounts.map(cat => (
          <li>
            <a href={`/categories/${cat.slug}`} class="cat-link">
              <h2 class="cat-name">{cat.name}</h2>
              <p class="cat-desc">{cat.description}</p>
              <p class="cat-count">{cat.count} piece{cat.count === 1 ? '' : 's'}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .categories {
    max-width: var(--measure);
    margin: 0 auto;
  }

  .page-header {
    margin: 1rem 0 3rem;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "SOFT" 40;
    font-weight: 500;
    font-size: clamp(1.85rem, 1.4rem + 1.8vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
    color: var(--fg-bright);
  }

  .page-dek {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--fg-dim);
    margin: 0;
  }

  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cat-list li + li {
    border-top: 1px solid var(--rule);
  }

  .cat-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .cat-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72, "SOFT" 40;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--fg-bright);
    margin: 0 0 0.4rem;
    transition: color 150ms ease;
  }

  .cat-link:hover .cat-name { color: var(--accent); }

  .cat-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--fg-dim);
    margin: 0 0 0.35rem;
    line-height: 1.5;
  }

  .cat-count {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
    margin: 0;
    letter-spacing: 0.01em;
  }
</style>
