---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Not found — Hologram Thoughts" description="This thread doesn't grow here — but the rest of the archive is still alive.">
  <section class="mt-16 mb-32 text-center">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-3">404</p>
    <h1 class="text-5xl tracking-tight mb-6" style="font-family: var(--font-display);">
      <span class="prismatic">This thread doesn't grow here.</span>
    </h1>
    <p class="text-lg text-[var(--color-ink-soft)] max-w-xl mx-auto leading-relaxed">
      The link you followed has gone to seed, or never sprouted. Try the
      <a href="/archive/" class="text-[var(--color-amber-bright)] hover:text-[var(--color-cyan)]">archive</a>,
      ask the <a href="/themes/" class="text-[var(--color-amber-bright)] hover:text-[var(--color-cyan)]">threads</a>,
      or wander back to the <a href="/" class="text-[var(--color-amber-bright)] hover:text-[var(--color-cyan)]">home page</a>.
    </p>
  </section>
</Layout>
