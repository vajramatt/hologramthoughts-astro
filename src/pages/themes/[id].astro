---
import Layout from '../../layouts/Layout.astro';
import taxonomy from '../../content/themes/taxonomy.json';
import { getCollection } from 'astro:content';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';
import { renderSynthesis } from '../../utils/sanitize-synthesis';
import { collectionPageGraph } from '../../utils/jsonld';

export async function getStaticPaths() {
  const themes = (taxonomy as any).themes;
  const themeDir = 'src/content/themes';
  const byTheme: Record<string, string[]> = {};
  let files: string[] = [];
  try {
    files = (await readdir(themeDir)).filter(f => f.endsWith('.json') && f !== 'taxonomy.json');
  } catch { files = []; }
  for (const f of files) {
    const sc = JSON.parse(await readFile(join(themeDir, f), 'utf8'));
    for (const id of sc.themeIds) {
      (byTheme[id] ??= []).push(sc.slug);
    }
  }
  return themes.map((t: any) => ({
    params: { id: t.id },
    props: { theme: t, slugs: byTheme[t.id] ?? [] }
  }));
}

const { theme, slugs } = Astro.props;
const all = await getCollection('blog', ({ data }) => !data.draft);
// Multi-key index — sidecar slugs can match frontmatter slug, astro slug, or id base
const bySlug = new Map<string, any>();
for (const p of all) {
  const idBase = p.id.replace(/\.md$/, '');
  if (p.data.slug) bySlug.set(p.data.slug, p);
  if ((p as any).slug) bySlug.set((p as any).slug, p);
  bySlug.set(idBase, p);
}
const posts = (slugs as string[])
  .map(s => bySlug.get(s))
  .filter(Boolean)
  .sort((a: any, b: any) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
// Chronological groups — one per year the thread was active
const byYear: Array<{ year: number; group: any[] }> = [];
for (const p of posts) {
  const year = p.data.pubDate.getUTCFullYear();
  const last = byYear[byYear.length - 1];
  if (last && last.year === year) last.group.push(p);
  else byYear.push({ year, group: [p] });
}
const jsonLd = collectionPageGraph({
  name: theme.name,
  description: theme.blurb || `Posts on ${theme.name}.`,
  url: `https://hologramthoughts.com/themes/${theme.id}/`,
  posts: posts.map((p: any) => ({
    title: p.data.title,
    url: `https://hologramthoughts.com/blog/${(p as any).slug ?? p.id.replace(/\.md$/, '')}/`,
  })),
});
---
<Layout title={`${theme.name} — Hologram Thoughts`} description={theme.blurb} jsonLd={jsonLd}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-2">Thread</p>
    <h1 class="text-5xl tracking-tight" style="font-family: var(--font-display);">{theme.name}</h1>
    {theme.blurb && <p class="text-xl text-[var(--color-ink-soft)] italic mt-4">{theme.blurb}</p>}
  </header>
  {theme.synthesis && (
    /* renderSynthesis() HTML-escapes the LLM text and restricts links to this
       site before it reaches set:html — see src/utils/sanitize-synthesis.ts */
    <div class="text-[var(--color-ink)] leading-relaxed mb-16" set:html={renderSynthesis(theme.synthesis as string)} />
  )}
  <section>
    <h2 class="text-xl mb-8" style="font-family: var(--font-display);"><span style="color: var(--color-amber-bright)">{posts.length}</span> posts, in order</h2>
    {byYear.map(({ year, group }) => (
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.18em] mb-2 pb-2 border-b border-[var(--color-border)]" style="font-family: var(--font-mono); color: var(--color-amber-bright);">{year}</p>
        <ul>
          {group.map((p: any) => {
            const slug = (p as any).slug ?? p!.id.replace(/\.md$/, '');
            return (
              <li>
                <a href={`/blog/${slug}/`} class="block group no-underline p-4 -mx-4 rounded-xl border border-transparent hover:border-[var(--color-border-strong)] hover:bg-[color-mix(in_oklch,var(--color-amber)_6%,transparent)] transition-all duration-[var(--dur-med)]">
                  <p class="text-xs uppercase tracking-[0.18em]" style="color: var(--color-amber-bright)">
                    {new Date(p!.data.pubDate).toLocaleDateString('en', { month: 'long', day: 'numeric', timeZone: 'UTC' })}
                  </p>
                  <p class="text-xl mt-1 text-[var(--color-ink)] group-hover:text-[var(--color-cyan)] transition-colors" style="font-family: var(--font-display);">{p!.data.title}</p>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </section>
</Layout>
