---
import Layout from '../layouts/Layout.astro';
import MuseHighlight from '../components/MuseHighlight.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import taxonomy from '../content/themes/taxonomy.json';
import { readFile } from 'node:fs/promises';
import yaml from 'js-yaml';

const all = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Use Astro's canonical post.slug (matches the URL the [slug].astro getStaticPaths generates)
const slugOf = (p: any) => p.slug ?? p.id.replace(/\.md$/, '');
// Frontmatter slug may differ from Astro slug — use frontmatter for sidecar JSON lookups
const sidecarKey = (p: any) => p.data.slug ?? p.slug ?? p.id.replace(/\.md$/, '');

// Read Muse picks (hand-curated overrides)
interface MusePicks {
  stories?: string[];
  latest?: string[];
  threads?: string[];
  featured_note?: string;
}
let picks: MusePicks = {};
try {
  picks = yaml.load(await readFile('src/data/muse-picks.yaml', 'utf8')) as MusePicks ?? {};
} catch { /* no picks file */ }

// Build a slug-keyed map so picks can use frontmatter slug, astro slug, or filename
const postBySlug = new Map<string, any>();
for (const p of all) {
  if (p.data.slug) postBySlug.set(p.data.slug, p);
  if ((p as any).slug) postBySlug.set((p as any).slug, p);
  postBySlug.set(p.id.replace(/\.md$/, ''), p);
}
const pickToSlug = (s: string) => {
  const p = postBySlug.get(s);
  return p ? slugOf(p) : null;
};

const latestSlugs = (picks.latest?.length ? picks.latest.map(pickToSlug).filter(Boolean) as string[]
  : all.slice(0, 5).map(slugOf));

const storySlugs = (picks.stories?.length ? picks.stories.map(pickToSlug).filter(Boolean) as string[]
  : all.filter(p => p.data.contentType === 'story').slice(0, 5).map(slugOf));

const themesById = new Map<string, any>((taxonomy as any).themes.map((t: any) => [t.id, t]));
const activeThemes = (picks.threads?.length
  ? picks.threads.map(id => themesById.get(id)).filter(Boolean)
  : [...(taxonomy as any).themes].sort((a: any, b: any) => b.postCount - a.postCount).slice(0, 6)
).map((t: any) => ({ id: t.id, name: t.name, blurb: t.blurb, postCount: t.postCount }));

const featuredNote = picks.featured_note?.trim() || null;

const featured = all.slice(0, 6);
const themeIdsBySlug: Record<string, string[]> = {};
for (const p of featured) {
  const urlSlug = slugOf(p);
  const key = sidecarKey(p);
  try {
    const sc = await import(`../content/themes/${key}.json`);
    themeIdsBySlug[urlSlug] = sc.default.themeIds ?? [];
  } catch {
    themeIdsBySlug[urlSlug] = [];
  }
}
---
<Layout title="Hologram Thoughts">
  <section class="mt-8 mb-16">
    <h1 class="text-5xl md:text-7xl tracking-tight leading-[1.05]" style="font-family: var(--font-display);">
      <span class="prismatic" style="background-size: 240% 100%; animation: vine-shift 30s linear infinite;">
        An archive of attention.
      </span>
    </h1>
    <p class="text-lg text-[var(--color-ink-soft)] mt-6 max-w-xl leading-relaxed">
      Twenty years of writing on consciousness, dharma, fatherhood, code, and the strange edges of culture — kept here so it doesn't get lost in the scroll.
    </p>
    {featuredNote && (
      <aside class="mt-10 max-w-xl pl-4 border-l-2 border-[var(--color-spore)]">
        <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">From Muse</p>
        <p class="text-base text-[var(--color-ink)] italic leading-relaxed" style="font-family: var(--font-display);">{featuredNote}</p>
      </aside>
    )}
  </section>

  <MuseHighlight latestSlugs={latestSlugs} activeThemes={activeThemes} storySlugs={storySlugs} />

  <section class="my-16">
    <h2 class="text-3xl mb-8" style="font-family: var(--font-display);">Recent</h2>
    <div class="space-y-2">
      {featured.map(p => {
        const s = slugOf(p);
        return <PostCard slug={s} title={p.data.title} pubDate={p.data.pubDate} themeIds={themeIdsBySlug[s]} />;
      })}
    </div>
  </section>
</Layout>
