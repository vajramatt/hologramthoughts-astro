---
import Layout from '../layouts/Layout.astro';
import MuseHighlight from '../components/MuseHighlight.astro';
import NetworkMap from '../components/NetworkMap.svelte';
import { getCollection } from 'astro:content';
import taxonomy from '../content/themes/taxonomy.json';
import { readFile } from 'node:fs/promises';
import yaml from 'js-yaml';

const all = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Use Astro's canonical post.slug (matches the URL the [slug].astro getStaticPaths generates)
const slugOf = (p: any) => p.slug ?? p.id.replace(/\.md$/, '');
// Frontmatter slug may differ from Astro slug — use frontmatter for sidecar JSON lookups
const sidecarKey = (p: any) => p.data.slug ?? p.slug ?? p.id.replace(/\.md$/, '');

// Read Muse picks (hand-curated overrides)
type StoryEntry = string | { series: string };
interface MusePicks {
  stories?: StoryEntry[];
  latest?: string[];
  threads?: string[];
  featured_note?: string;
}
let picks: MusePicks = {};
try {
  picks = yaml.load(await readFile('src/data/muse-picks.yaml', 'utf8')) as MusePicks ?? {};
} catch { /* no picks file */ }

// Build a slug-keyed map so picks can use frontmatter slug, astro slug, or filename
const postBySlug = new Map<string, any>();
for (const p of all) {
  if (p.data.slug) postBySlug.set(p.data.slug, p);
  if ((p as any).slug) postBySlug.set((p as any).slug, p);
  postBySlug.set(p.id.replace(/\.md$/, ''), p);
}
const pickToSlug = (s: string) => {
  const p = postBySlug.get(s);
  return p ? slugOf(p) : null;
};

const latestSlugs = (picks.latest?.length ? picks.latest.map(pickToSlug).filter(Boolean) as string[]
  : all.slice(0, 5).map(slugOf));

// Stories: mix of single posts and series groups.
// Single → { kind: 'post', slug, title, pubDate }
// Series → { kind: 'series', name, parts: [{ slug, title, pubDate, order }] }
type StoryItem =
  | { kind: 'post'; slug: string; title: string; pubDate: Date }
  | { kind: 'series'; name: string; parts: Array<{ slug: string; title: string; pubDate: Date; order: number }> };
const stories: StoryItem[] = [];
if (picks.stories?.length) {
  for (const entry of picks.stories) {
    if (typeof entry === 'string') {
      const p = postBySlug.get(entry);
      if (p) stories.push({ kind: 'post', slug: slugOf(p), title: p.data.title, pubDate: p.data.pubDate });
    } else if (entry?.series) {
      const seriesName = entry.series;
      const parts = all
        .filter(p => p.data.series === seriesName)
        .map(p => ({ slug: slugOf(p), title: p.data.title, pubDate: p.data.pubDate, order: p.data.seriesOrder ?? 999 }))
        .sort((a, b) => a.order - b.order);
      if (parts.length) stories.push({ kind: 'series', name: seriesName, parts });
    }
  }
} else {
  const fallback = all.filter(p => p.data.contentType === 'story').slice(0, 5);
  for (const p of fallback) {
    stories.push({ kind: 'post', slug: slugOf(p), title: p.data.title, pubDate: p.data.pubDate });
  }
}

const themesById = new Map<string, any>((taxonomy as any).themes.map((t: any) => [t.id, t]));
const activeThemes = (picks.threads?.length
  ? picks.threads.map(id => themesById.get(id)).filter(Boolean)
  : [...(taxonomy as any).themes].sort((a: any, b: any) => b.postCount - a.postCount).slice(0, 6)
).map((t: any) => ({ id: t.id, name: t.name, blurb: t.blurb, postCount: t.postCount }));

const featuredNote = picks.featured_note?.trim() || null;

// ── Mycelial subway map: themes as stations on flowing, time-ordered lines ──
// Each theme is a station. x = when the thread was most active (median post date),
// so the whole map flows left→right across the archive's lifetime. Themes are grouped
// into "lines" by which hub-theme they co-occur with most. Cross-line links = interchanges.
// All positions are computed here at build time (deterministic, no physics → no load jitter).
const validThemeIds = new Set<string>((taxonomy as any).themes.map((t: any) => t.id));
const sidecarMods = import.meta.glob('../content/themes/*.json', { eager: true });
const cooccur = new Map<string, number>();
const themeDates = new Map<string, number[]>();
const pairKey = (a: string, b: string) => (a < b ? `${a}|${b}` : `${b}|${a}`);
for (const mod of Object.values(sidecarMods)) {
  const sc = (mod as any).default;
  if (!sc || !Array.isArray(sc.themeIds)) continue; // skip taxonomy.json
  const ids = [...new Set<string>(sc.themeIds.filter((id: string) => validThemeIds.has(id)))].sort();
  const post = postBySlug.get(sc.slug);
  const ms = post ? post.data.pubDate.valueOf() : null;
  for (const id of ids) {
    if (ms == null) continue;
    if (!themeDates.has(id)) themeDates.set(id, []);
    themeDates.get(id)!.push(ms);
  }
  for (let i = 0; i < ids.length; i++)
    for (let j = i + 1; j < ids.length; j++) {
      const k = `${ids[i]}|${ids[j]}`;
      cooccur.set(k, (cooccur.get(k) ?? 0) + 1);
    }
}
const coW = (a: string, b: string) => cooccur.get(pairKey(a, b)) ?? 0;
const median = (arr: number[]) => { const s = [...arr].sort((a, b) => a - b); return s.length ? s[Math.floor(s.length / 2)] : null; };

const mapThemes = [...(taxonomy as any).themes].filter((t: any) => t.postCount > 0);
const times = all.map((p: any) => p.data.pubDate.valueOf());
const minT = Math.min(...times);

// lines: top-K themes by postCount become hub anchors; each other theme joins the hub it shares most posts with
const LANES = 7;
const seeds = [...mapThemes].sort((a, b) => b.postCount - a.postCount).slice(0, LANES).map((t: any) => t.id);
// Balanced assignment: each non-seed joins the hub it co-occurs with most, but lines are capped
// so the big hubs don't swallow everything — this keeps all LANES populated as real lines.
const laneOf = new Map<string, number>();
const laneFill = new Array(LANES).fill(0);
for (const t of mapThemes) { const si = seeds.indexOf(t.id); if (si >= 0) { laneOf.set(t.id, si); laneFill[si]++; } }
const cap = Math.ceil(mapThemes.length / LANES);
const nonSeeds = [...mapThemes].filter((t: any) => !seeds.includes(t.id)).sort((a: any, b: any) => b.postCount - a.postCount);
for (const t of nonSeeds) {
  const ranked = seeds.map((s: string, i: number) => ({ i, w: coW(t.id, s) })).sort((a, b) => b.w - a.w);
  const pick = ranked.find((o) => laneFill[o.i] < cap) ?? ranked[0];
  laneOf.set(t.id, pick.i); laneFill[pick.i]++;
}

const X0 = 0.05, X1 = 0.95;
const laneBase = (i: number) => 0.15 + (LANES > 1 ? (i / (LANES - 1)) * 0.7 : 0);
const infoById = new Map((taxonomy as any).themes.map((t: any) => [t.id, t]));

// Transit maps distort space for legibility: stations keep their chronological ORDER
// (by median post date) but are spaced by rank, not by elapsed time — otherwise the
// early-archive cluster crushes into the left edge and most of the canvas is dead.
// Year ticks are interpolated back onto the rank scale below, so time stays readable.
const medById = new Map<string, number>();
for (const t of mapThemes) medById.set(t.id, median(themeDates.get(t.id) ?? []) ?? minT);
const sortedMeds = [...medById.values()].sort((a, b) => a - b);
const nMed = sortedMeds.length;
// The axis runs from the oldest post to today, blending two scales: a rank scale
// (anchors: oldest post → theme medians evenly spaced → today) that decompresses the
// early-archive cluster, and a linear-time component that keeps the years honestly
// proportioned so ticks land readably out to the present. Stations and ticks share
// the same mapping, so a station always sits over its true era.
const NOW = Date.now();
const anchors = [minT, ...sortedMeds, Math.max(NOW, (sortedMeds[nMed - 1] ?? NOW) + 1)];
const nA = anchors.length;
const anchorX = (i: number) => X0 + (i / (nA - 1)) * (X1 - X0);
const xRank = (d: number) => {
  if (d <= anchors[0]) return X0;
  if (d >= anchors[nA - 1]) return X1;
  let i = 0;
  while (i < nA - 2 && anchors[i + 1] < d) i++;
  return anchorX(i + (d - anchors[i]) / (anchors[i + 1] - anchors[i] || 1));
};
const xLin = (d: number) => Math.min(X1, Math.max(X0, X0 + ((d - minT) / (NOW - minT || 1)) * (X1 - X0)));
const BLEND = 0.35; // how much linear time to mix back in
const xOfDate = (d: number) => BLEND * xLin(d) + (1 - BLEND) * xRank(d);

let stations = mapThemes.map((t: any) => {
  const lane = laneOf.get(t.id)!;
  const info: any = infoById.get(t.id);
  return { id: t.id, name: t.name, postCount: t.postCount, lane, x: xOfDate(medById.get(t.id)!), y: 0,
    isHub: seeds.includes(t.id), below: false, blurb: info?.blurb ?? '', synthesis: info?.synthesis ?? '' };
});
// spacing pass within each line so same-rank neighbours don't stack (forward then backward,
// so nothing piles up at the right edge), then a gentle wander for organic flow.
// Labels alternate above/below along each line to halve collisions.
const MINGAP = 0.055;
for (let i = 0; i < LANES; i++) {
  const lane = stations.filter((s) => s.lane === i).sort((a, b) => a.x - b.x);
  for (let j = 1; j < lane.length; j++)
    if (lane[j].x - lane[j - 1].x < MINGAP) lane[j].x = Math.min(X1, lane[j - 1].x + MINGAP);
  for (let j = lane.length - 2; j >= 0; j--)
    if (lane[j + 1].x - lane[j].x < MINGAP) lane[j].x = Math.max(X0, lane[j + 1].x - MINGAP);
  lane.forEach((s, j) => {
    s.y = laneBase(i) + Math.sin(s.x * Math.PI * 3.5 + i * 1.7) * 0.04;
    s.below = (j + i) % 2 === 1;
  });
}
// cross-line collision relax: big hubs on adjacent lines can still overlap after the
// wander. Nudge colliding pairs apart vertically — x is time order, so y gives way.
// Approximate px space matches the component's stationDia and a typical canvas size.
const stationDia = (pc: number) => (5.5 + Math.sqrt(pc) * 2.1) * 2;
const PXW = 1300, PXH = 600;
for (let pass = 0; pass < 6; pass++) {
  for (let a = 0; a < stations.length; a++)
    for (let b = a + 1; b < stations.length; b++) {
      const A = stations[a], B = stations[b];
      const dx = (A.x - B.x) * PXW, dy = (A.y - B.y) * PXH;
      const need = (stationDia(A.postCount) + stationDia(B.postCount)) / 2 + 8;
      const d = Math.hypot(dx, dy);
      if (d >= need) continue;
      const push = (need - d) / 2 / PXH;
      const dir = A.y <= B.y ? -1 : 1;
      A.y = Math.min(0.88, Math.max(0.08, A.y + dir * push));
      B.y = Math.min(0.88, Math.max(0.08, B.y - dir * push));
    }
}
// label sides: the per-lane alternation above is only a seed — refine it greedily
// (biggest stations claim space first), flipping each label to whichever side of its
// station overlaps less with already-placed labels and neighbouring dots.
const placedBoxes: { x0: number; x1: number; y0: number; y1: number }[] = [];
for (const s of stations) {
  const r = stationDia(s.postCount) / 2 + 2;
  placedBoxes.push({ x0: s.x * PXW - r, x1: s.x * PXW + r, y0: s.y * PXH - r, y1: s.y * PXH + r });
}
const labelBox = (s: any, below: boolean) => {
  const wpx = s.name.length * 4.8 + 8, hpx = 13;
  const cx = s.x * PXW;
  const off = stationDia(s.postCount) / 2 + 4 + hpx / 2;
  const cy = s.y * PXH + (below ? off : -off);
  return { x0: cx - wpx / 2, x1: cx + wpx / 2, y0: cy - hpx / 2, y1: cy + hpx / 2 };
};
const overlapArea = (r: { x0: number; x1: number; y0: number; y1: number }) =>
  placedBoxes.reduce((sum, p) => {
    const ox = Math.max(0, Math.min(r.x1, p.x1) - Math.max(r.x0, p.x0));
    const oy = Math.max(0, Math.min(r.y1, p.y1) - Math.max(r.y0, p.y0));
    return sum + ox * oy;
  }, 0);
for (const s of [...stations].sort((a, b) => b.postCount - a.postCount)) {
  const up = labelBox(s, false), down = labelBox(s, true);
  const ovUp = overlapArea(up), ovDown = overlapArea(down);
  if (ovDown !== ovUp) s.below = ovDown < ovUp;
  placedBoxes.push(s.below ? down : up);
}
// keyboard tab order follows the lines: lane by lane, left to right
stations.sort((a, b) => a.lane - b.lane || a.x - b.x);

// underweb: every cross-line pair that ever shared a post. Weight = shared count; the
// component fades each thread by weight, so single-post bonds whisper and strong bonds read.
// (Same-line pairs are already joined by their line's spline, so skip those.)
const laneById = new Map(stations.map((s) => [s.id, s.lane]));
const interchanges: { a: string; b: string; w: number }[] = [];
for (const [k, w] of cooccur.entries()) {
  const [a, b] = k.split('|');
  if (!laneById.has(a) || !laneById.has(b)) continue;
  if (laneById.get(a) === laneById.get(b)) continue;
  interchanges.push({ a, b, w });
}

// year ticks live on the anchor scale — unevenly spaced, which honestly shows where the
// archive ran hot. Oldest post to today, every 2 years, dropping ticks that would crowd.
const yearOf = (ms: number) => new Date(ms).getFullYear();
const minYear = yearOf(minT), maxYear = yearOf(NOW);
const yearTicks: { year: number | string; x: number }[] = [];
let lastTickX = -1;
for (let y = Math.ceil(minYear / 2) * 2; y <= maxYear; y += 2) {
  const x = xOfDate(new Date(y, 0, 1).valueOf());
  if (x - lastTickX < 0.045) continue;
  yearTicks.push({ year: y, x });
  lastTickX = x;
}
// the right edge is the present — give it its own marker
while (yearTicks.length && X1 - yearTicks[yearTicks.length - 1].x < 0.05) yearTicks.pop();
yearTicks.push({ year: 'now', x: X1 });

const mapData = { stations, interchanges, laneCount: LANES, yearTicks };

// themeIds for each Latest post (URL-slug keyed; sidecar looked up by multi-key)
const themeIdsByLatestSlug: Record<string, string[]> = {};
for (const s of latestSlugs) {
  const p = postBySlug.get(s);
  if (!p) { themeIdsByLatestSlug[s] = []; continue; }
  try {
    const sc = await import(`../content/themes/${sidecarKey(p)}.json`);
    themeIdsByLatestSlug[s] = sc.default.themeIds ?? [];
  } catch {
    themeIdsByLatestSlug[s] = [];
  }
}
---
<Layout title="Hologram Thoughts" description="Twenty years of writing on consciousness, dharma, fatherhood, code, and the strange edges of culture — an archive of attention, curated by Muse.">
  <section class="mt-8 mb-16">
    <p class="text-xs md:text-sm mb-6" style="font-family: var(--font-mono);" aria-hidden="true"><span style="color: var(--color-green);">muse@hologram</span><span style="color: var(--color-ink-faint);">:</span><span style="color: var(--color-blue);">~</span><span style="color: var(--color-ink-faint);">$</span> <span class="term-cmd-wrap"><span class="term-ghost">replay ./archive --era 2006..2026</span><span class="term-cmd" style="color: var(--color-ink-soft);"><span data-tw-cmd>replay ./archive --era 2006..2026</span><span class="term-mini-caret" data-cmd-caret></span></span></span></p>
    <h1 class="relative text-5xl md:text-7xl tracking-tight leading-[1.05]" style="font-family: var(--font-display);" aria-label="An archive of attention.">
      <span class="hero-ghost" aria-hidden="true">An archive of attention.</span>
      <span class="hero-typed" aria-hidden="true"><span class="prismatic" style="background-size: 240% 100%; animation: scanline-shift 30s linear infinite;" data-tw-h1>An archive of attention.</span><span class="hero-caret" data-h1-caret></span></span>
    </h1>
    <p class="hero-reveal text-lg text-[var(--color-ink-soft)] mt-6 max-w-xl leading-relaxed" data-tw-reveal>
      Twenty years of writing on consciousness, dharma, fatherhood, code, and the strange edges of culture — kept here so it doesn't get lost in the scroll.
    </p>
    {featuredNote && (
      <aside class="hero-reveal mt-10 max-w-xl pl-4 border-l-2 border-[var(--color-amber)]" data-tw-reveal>
        <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">From Muse</p>
        <p class="text-base text-[var(--color-ink)] italic leading-relaxed" style="font-family: var(--font-display);">{featuredNote}</p>
      </aside>
    )}
  </section>
  <script is:inline>
    // Muse types the session in: prompt command first, then the headline. The full
    // text ships in the HTML (SEO / no-JS); this only animates when motion is allowed.
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const cmd = document.querySelector('[data-tw-cmd]');
      const h1 = document.querySelector('[data-tw-h1]');
      const cmdCaret = document.querySelector('[data-cmd-caret]');
      const h1Caret = document.querySelector('[data-h1-caret]');
      const reveals = document.querySelectorAll('[data-tw-reveal]');
      if (!cmd || !h1 || !cmdCaret || !h1Caret) return;
      const cmdText = cmd.textContent;
      const h1Text = h1.textContent;
      cmd.textContent = '';
      h1.textContent = '';
      h1Caret.classList.add('caret-off');
      reveals.forEach((el) => el.classList.add('tw-wait'));

      // The whole sequence is one elapsed-time event list, replayed idempotently.
      // Driven by rAF (smooth in the foreground) with a timeout fallback, because
      // browsers throttle/pause both in hidden or occluded tabs — on any tick the
      // timeline catches up to wall-clock, so a backgrounded load just fast-forwards.
      const events = [];
      let t = 250;
      events.push([t, () => cmdCaret.classList.add('caret-typing')]);
      for (let k = 0; k < cmdText.length; k++) {
        t += 30 * (0.6 + Math.random() * 0.9);
        const n = k + 1;
        events.push([t, () => { cmd.textContent = cmdText.slice(0, n); }]);
      }
      events.push([t += 120, () => cmdCaret.classList.remove('caret-typing')]);
      events.push([t += 380, () => {
        h1Caret.classList.remove('caret-off');
        h1Caret.classList.add('caret-typing');
      }]);
      for (let k = 0; k < h1Text.length; k++) {
        t += 52 * (0.6 + Math.random() * 0.9);
        const n = k + 1;
        events.push([t, () => { h1.textContent = h1Text.slice(0, n); }]);
      }
      events.push([t += 150, () => h1Caret.classList.remove('caret-typing')]);
      events.push([t += 250, () => reveals.forEach((el) => el.classList.remove('tw-wait'))]);

      const startAt = performance.now();
      let idx = 0;
      let tid = 0;
      let rid = 0;
      const step = () => {
        clearTimeout(tid);
        cancelAnimationFrame(rid);
        const elapsed = performance.now() - startAt;
        while (idx < events.length && events[idx][0] <= elapsed) events[idx++][1]();
        if (idx < events.length) {
          rid = requestAnimationFrame(step);
          tid = setTimeout(step, 150);
        }
      };
      step();
    })();
  </script>

  <MuseHighlight latestSlugs={latestSlugs} activeThemes={activeThemes} stories={stories} themeIdsBySlug={themeIdsByLatestSlug} />

  <section class="mt-24 mb-12">
    <div class="text-center max-w-xl mx-auto mb-6">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">The understory</p>
      <h2 class="text-3xl md:text-4xl mt-1" style="font-family: var(--font-display);">Lines through the archive</h2>
      <p class="text-sm text-[var(--color-ink-soft)] mt-3 leading-relaxed">
        Every thread laid along the years it ran, grouped into the lines they travel together. Spores drift forward through time. Touch a station to open it below.
      </p>
    </div>
    <div style="width:100vw;position:relative;left:50%;transform:translateX(-50%);">
      <NetworkMap data={mapData} client:visible />
    </div>
  </section>
</Layout>

<style>
  /* Ghost/overlay typewriter: the invisible full text reserves layout (no CLS),
     the absolutely-positioned twin types over it. Same font metrics → same wrap. */
  .term-cmd-wrap { position: relative; display: inline-block; }
  .term-ghost { visibility: hidden; white-space: pre; }
  .term-cmd { position: absolute; left: 0; top: 0; white-space: pre; }
  .term-mini-caret {
    display: inline-block;
    width: 0.55ch;
    height: 1em;
    margin-left: 0.12ch;
    transform: translateY(0.18em);
    background: var(--color-green);
    opacity: 0;
  }
  .term-mini-caret.caret-typing { opacity: 1; }

  .hero-ghost { visibility: hidden; }
  .hero-typed { position: absolute; inset: 0; }
  .hero-caret {
    display: inline-block;
    width: 0.48ch;
    height: 0.78em;
    margin-left: 0.14ch;
    transform: translateY(0.06em);
    background: var(--color-green);
    box-shadow: 0 0 18px color-mix(in oklch, var(--color-green) 55%, transparent);
    animation: hero-blink 1.06s steps(1) infinite;
  }
  .hero-caret.caret-typing { animation: none; opacity: 1; }
  .hero-caret.caret-off { animation: none; opacity: 0; }
  @keyframes hero-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  .hero-reveal { transition: opacity 600ms var(--ease-grow), transform 600ms var(--ease-grow); }
  .hero-reveal.tw-wait { opacity: 0; transform: translateY(10px); }

  @media (prefers-reduced-motion: reduce) {
    .hero-caret { animation: none; opacity: 1; }
  }
</style>
