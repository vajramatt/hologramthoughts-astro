---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

function getExcerpt(body, maxLength = 220) {
  const text = body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/#+\s+/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/---/g, '')
    .replace(/\s{2,}/g, ' ')
    .replace(/\n+/g, ' ')
    .trim();
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).replace(/\s+\S*$/, '') + '…';
}

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const [featured, ...rest] = sortedPosts;
const recent = rest.slice(0, 7);

const formatDate = (d) => d.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Layout title="Hologram Thoughts — ideas last forever">
  <div class="page">
    <SiteHeader activePage="home" />

    <main class="page-main home">

      <section class="intro">
        <p>
          Spiritual, philosophical, and creative writing. Buddhism, meditation,
          consciousness, fiction. A long conversation with whoever is reading —
          <a href="/archive">{allPosts.length} pieces</a> since 2006.
        </p>
      </section>

      {featured && (
        <article class="featured">
          <p class="eyebrow">Latest</p>
          <h2 class="featured-title">
            <a href={`/blog/${featured.slug}`}>{featured.data.title}</a>
          </h2>
          <p class="featured-meta">
            <time datetime={featured.data.pubDate.toISOString()}>{formatDate(featured.data.pubDate)}</time>
            {featured.data.categories?.length > 0 && (
              <> <span class="sep">·</span> <span class="cats">{featured.data.categories.join(' · ')}</span></>
            )}
          </p>
          <p class="featured-excerpt">{featured.data.description || getExcerpt(featured.body, 260)}</p>
          <p class="featured-link">
            <a href={`/blog/${featured.slug}`}>Continue reading →</a>
          </p>
        </article>
      )}

      {recent.length > 0 && (
        <section class="recent">
          <p class="eyebrow">Recently</p>
          <ul class="post-list">
            {recent.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`} class="post-link">
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-excerpt">{post.data.description || getExcerpt(post.body, 160)}</p>
                  <p class="post-meta">
                    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                    {post.data.categories?.length > 0 && (
                      <> <span class="sep">·</span> <span>{post.data.categories[0]}</span></>
                    )}
                  </p>
                </a>
              </li>
            ))}
          </ul>

          <p class="more-link">
            <a href="/archive">Browse the full archive — {allPosts.length} pieces →</a>
          </p>
        </section>
      )}

    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .home {
    max-width: var(--measure);
    margin: 0 auto;
    width: 100%;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  /* ─── Intro paragraph ─── */
  .intro {
    margin: 1rem 0 3.5rem;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--fg-dim);
    font-style: italic;
    margin: 0;
    max-width: 32rem;
  }

  .intro a {
    font-style: italic;
    color: var(--fg);
  }

  /* ─── Featured (latest) ─── */
  .featured {
    margin-bottom: 3.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--rule);
  }

  .featured-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "SOFT" 40;
    font-weight: 500;
    font-size: clamp(1.85rem, 1.4rem + 1.8vw, 2.65rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }

  .featured-title a {
    color: var(--fg-bright);
    text-decoration: none;
  }
  .featured-title a:hover { color: var(--accent); }

  .featured-meta {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0 0 1.25rem;
    letter-spacing: 0.01em;
  }

  .featured-meta .sep { color: var(--rule); margin: 0 0.4em; }
  .featured-meta .cats { font-style: italic; }

  .featured-excerpt {
    font-size: 1.075rem;
    line-height: 1.65;
    color: var(--fg);
    margin: 0 0 1.25rem;
  }

  .featured-link a {
    font-style: italic;
    font-size: 0.95rem;
    text-decoration: none;
  }

  /* ─── Post list (recent) ─── */
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li {
    margin: 0;
  }

  .post-list li + li {
    border-top: 1px solid var(--rule);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 48, "SOFT" 40;
    font-weight: 500;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--fg-bright);
    margin: 0 0 0.4rem;
    text-wrap: balance;
    transition: color 150ms ease;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-excerpt {
    color: var(--fg-dim);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 0.5rem;
    text-wrap: pretty;
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .post-meta .sep { color: var(--rule); margin: 0 0.35em; }

  /* ─── "Browse full archive" link ─── */
  .more-link {
    margin: 2.5rem 0 0;
    text-align: center;
    font-style: italic;
    font-size: 0.95rem;
  }

  .more-link a {
    text-decoration: none;
    color: var(--fg-dim);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .more-link a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ─── Section spacing ─── */
  .recent { margin-top: 0; }
</style>
