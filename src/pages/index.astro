---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

function getExcerpt(body, maxLength = 160) {
  const text = body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/#+\s+/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/---/g, '')
    .replace(/\s{2,}/g, ' ')
    .replace(/\n+/g, ' ')
    .trim();
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).replace(/\s+\S*$/, '') + '…';
}

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const recentPosts = sortedPosts.slice(0, 8);

const categoryData = {
  'Dharma Writings':           { count: 0, slug: 'dharma-writings' },
  'Creative Writing':          { count: 0, slug: 'creative-writing' },
  'Consciousness & Philosophy':{ count: 0, slug: 'consciousness-philosophy' },
  'Practice & Inner Life':     { count: 0, slug: 'practice-inner-life' },
  'Other':                     { count: 0, slug: 'other' }
};

allPosts.forEach(post => {
  post.data.categories.forEach(category => {
    if (categoryData[category]) categoryData[category].count++;
  });
});
---

<Layout title="Hologram Thoughts - Ideas Last Forever">
  <SiteHeader activePage="home" />

  <main>
    <div class="terminal-main">
      <div class="shell-session">

        <!-- ls command -->
        <div class="shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd">ls -lt ~/dharma/posts/ | head -8</span>
        </div>

        <div class="shell-output posts-listing">
          {recentPosts.map((post) => (
            <div class="post-entry">
              <div class="post-entry-header">
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                  })}
                </span>
                <a href={`/blog/${post.slug}`} class="post-title">{post.data.title}</a>
              </div>
              <p class="post-excerpt">{getExcerpt(post.body)}</p>
            </div>
          ))}
        </div>

        <div class="view-all-line shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd"><a href="/archive">ls ~/dharma/posts/ | wc -l &nbsp;# view all {allPosts.length} posts</a></span>
        </div>

        <!-- cat README -->
        <div class="shell-line readme-cmd">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd">read DHARMA.md</span>
        </div>

        <div class="shell-output readme-output">
          <p class="readme-desc">Spiritual, philosophical, and creative writing. Buddhism, meditation, consciousness, fiction. Ideas last forever.</p>

          <div class="categories-list">
            {Object.entries(categoryData)
              .filter(([_, data]) => data.count > 0)
              .sort((a, b) => b[1].count - a[1].count)
              .map(([name, data]) => (
                <div class="readme-entry">
                  <span class="readme-arrow">→</span>
                  <a href={`/categories/${data.slug}`} class="readme-link">{name}</a>
                  <span class="readme-count">{data.count} posts</span>
                </div>
              ))
            }
          </div>
        </div>

      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  main {
    margin: 0;
    padding: 0;
  }

  /* Shell session */
  .shell-session {
    font-size: 14px;
    line-height: 1.5;
  }

  .shell-line {
    margin-bottom: 0.5rem;
  }

  .shell-line.readme-cmd {
    margin-top: 1.5rem;
  }

  .ps1 {
    font-weight: 700;
    margin-right: 0.5em;
  }

  .ps1-user   { color: var(--term-green); }
  .ps1-sep    { color: var(--term-fg-dim); }
  .ps1-dir    { color: #818cf8; }
  .ps1-dollar { color: var(--term-muted); margin-left: 0.1em; }

  .shell-cmd {
    color: var(--term-fg);
  }

  .shell-cmd a {
    color: var(--term-fg);
    text-decoration: none;
  }

  .shell-cmd a:hover {
    color: var(--term-accent-hover);
  }

  .shell-output {
    margin-bottom: 0.5rem;
    color: var(--term-fg-dim);
  }

  /* Post listing */
  .posts-listing {
    margin-bottom: 0.75rem;
  }

  .post-entry {
    padding: 10px 0;
    border-bottom: 1px dashed var(--term-border);
  }

  .post-entry:last-child {
    border-bottom: none;
  }

  .post-entry-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 4px;
  }

  .post-date {
    color: var(--term-muted);
    font-size: 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-title {
    color: var(--term-accent);
    text-decoration: none;
    font-weight: 700;
    line-height: 1.4;
    text-shadow: var(--term-glow);
  }

  .post-title:hover {
    color: var(--term-accent-hover);
  }

  .post-excerpt {
    color: var(--term-fg-dim);
    font-size: 12px;
    line-height: 1.5;
    margin: 0;
    padding-left: calc(12ch + 1rem); /* align under title, past the date */
  }

  /* README section */
  .readme-output {
    color: var(--term-fg-dim);
  }

  .readme-desc {
    color: var(--term-fg-dim);
    margin-bottom: 1rem;
  }

  .categories-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .readme-entry {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .readme-arrow {
    color: var(--term-muted);
    flex-shrink: 0;
  }

  .readme-link {
    color: #bd93f9;
    text-decoration: none;
    font-weight: 600;
  }

  .readme-link:hover {
    color: var(--term-green);
  }

  .readme-count {
    color: var(--term-muted);
    font-size: 12px;
  }
</style>
