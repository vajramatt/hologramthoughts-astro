---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ThemeChipStrip from '../../components/ThemeChipStrip.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import type { PostSidecar } from '../../lib/themes';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );

  return sortedPosts.map((post, index) => {
    let prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    let nextPost = index > 0 ? sortedPosts[index - 1] : null;

    // If this post belongs to a series, use series order for prev/next
    if (post.data.series && post.data.seriesOrder !== undefined) {
      const seriesPosts = posts
        .filter(p => p.data.series === post.data.series && p.data.seriesOrder !== undefined)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
      const seriesIndex = seriesPosts.findIndex(p => p.slug === post.slug);
      prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
      nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
    }

    return {
      params: { slug: post.slug },
      props: { post, nextPost, prevPost },
    };
  });
}

const { post, nextPost, prevPost } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await post.render();

let sidecar: PostSidecar = { slug: '', themeIds: [], related: [] };
try {
  const slug = post.data.slug ?? post.slug;
  sidecar = (await import(`../../content/themes/${slug}.json`)).default;
} catch { /* no sidecar */ }

const dateStr = post.data.pubDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const ogDescription = post.data.description
  ?? post.body
      .replace(/^---[\s\S]*?---\n?/, '')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/https?:\/\/\S+/g, '')
      .replace(/#+\s+/g, '')
      .replace(/\*\*(.*?)\*\*/g, '$1')
      .replace(/\*(.*?)\*/g, '$1')
      .replace(/`[^`]+`/g, '')
      .replace(/^\s*[-*+]\s+/gm, '')
      .replace(/\s{2,}/g, ' ')
      .replace(/\n+/g, ' ')
      .trim()
      .substring(0, 200)
      .replace(/\s+\S*$/, '') + '…';

const publishedTime = post.data.pubDate?.toISOString();
const canonicalUrl = `https://hologramthoughts.com/blog/${post.slug}/`;
const readingTime = remarkPluginFrontmatter?.readingTime;
const isSeries = !!post.data.series;
---

<Layout
  title={`${post.data.title} — Hologram Thoughts`}
  description={ogDescription}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
>
  <ReadingProgress />

  <article>
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-3">
        {dateStr}
        {readingTime && <span> · {readingTime} min</span>}
        {post.data.categories && post.data.categories.length > 0 && (
          <span> · {post.data.categories.join(' · ')}</span>
        )}
      </p>
      <h1 class="text-4xl md:text-5xl tracking-tight leading-[1.1] text-[var(--color-ink)]" style="font-family: var(--font-display);">{post.data.title}</h1>
      {post.data.description && (
        <p class="text-lg text-[var(--color-ink-soft)] mt-4 leading-relaxed">{post.data.description}</p>
      )}
    </header>

    <TableOfContents headings={headings} />

    <div class="prose post-content">
      <Content />
    </div>

    <ThemeChipStrip themeIds={sidecar.themeIds} />
    <RelatedPosts related={sidecar.related} />
  </article>

  {(prevPost || nextPost) && (
    <nav class="mt-16 pt-8 border-t border-[var(--glass-border)] grid md:grid-cols-2 gap-6">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="group no-underline block">
          <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">
            {isSeries ? '← Previous' : '← Older'}
          </p>
          <p class="text-[var(--color-ink)] group-hover:text-[var(--color-moss-deep)] transition-colors" style="font-family: var(--font-display);">{prevPost.data.title}</p>
        </a>
      ) : <span />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="group no-underline block md:text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">
            {isSeries ? 'Next →' : 'Newer →'}
          </p>
          <p class="text-[var(--color-ink)] group-hover:text-[var(--color-moss-deep)] transition-colors" style="font-family: var(--font-display);">{nextPost.data.title}</p>
        </a>
      ) : <span />}
    </nav>
  )}
</Layout>

<style>
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink);
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-weight: 480;
    letter-spacing: -0.015em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .post-content :global(h1) { font-size: 2rem; }
  .post-content :global(h2) { font-size: 1.65rem; }
  .post-content :global(h3) { font-size: 1.35rem; }
  .post-content :global(h4) { font-size: 1.15rem; }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.75;
  }

  .post-content :global(blockquote) {
    margin: 1.5rem 0 1.5rem 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--glass-border);
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(em)     { font-style: italic; }
  .post-content :global(strong) { font-weight: 600; }

  .post-content :global(code) {
    background: color-mix(in oklch, var(--color-moss) 8%, transparent);
    color: var(--color-ink);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: var(--font-mono);
  }

  .post-content :global(pre) {
    background: color-mix(in oklch, var(--color-ink) 5%, transparent);
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .post-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--glass-border);
    margin: 2.5rem 0;
  }

  .post-content :global(a) {
    color: var(--color-moss-deep);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-bloom);
  }

  .post-content :global(a:hover) {
    color: var(--color-sky-deep);
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5rem 0;
  }
</style>
