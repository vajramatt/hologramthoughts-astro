---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );

  return sortedPosts.map((post, index) => {
    let prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    let nextPost = index > 0 ? sortedPosts[index - 1] : null;

    // If this post belongs to a series, use series order for prev/next
    if (post.data.series && post.data.seriesOrder !== undefined) {
      const seriesPosts = posts
        .filter(p => p.data.series === post.data.series && p.data.seriesOrder !== undefined)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
      const seriesIndex = seriesPosts.findIndex(p => p.slug === post.slug);
      prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
      nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
    }

    return {
      params: { slug: post.slug },
      props: { post, nextPost, prevPost },
    };
  });
}

const { post, nextPost, prevPost } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await post.render();

const dateStr = post.data.pubDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const ogDescription = post.data.description
  ?? post.body
      .replace(/^---[\s\S]*?---\n?/, '')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/https?:\/\/\S+/g, '')
      .replace(/#+\s+/g, '')
      .replace(/\*\*(.*?)\*\*/g, '$1')
      .replace(/\*(.*?)\*/g, '$1')
      .replace(/`[^`]+`/g, '')
      .replace(/^\s*[-*+]\s+/gm, '')
      .replace(/\s{2,}/g, ' ')
      .replace(/\n+/g, ' ')
      .trim()
      .substring(0, 200)
      .replace(/\s+\S*$/, '') + '…';

const publishedTime = post.data.pubDate?.toISOString();
const canonicalUrl = `https://hologramthoughts.com/blog/${post.slug}/`;
---

<Layout
  title={`${post.data.title} - Hologram Thoughts`}
  description={ogDescription}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
>
  <ReadingProgress />
  <SiteHeader activePage="home" />

  <main>
    <div class="terminal-main">
      <div class="shell-session">
        <div class="shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd">read ./{post.slug}.md</span>
        </div>

        <div class="shell-output">
          <article class="post">
            <header class="post-header">
              {post.data.categories && post.data.categories.length > 0 && (
                <div class="category-label">{post.data.categories.join(' · ')}</div>
              )}
              <h1>{post.data.title}</h1>
              <p class="post-meta">
                {dateStr} — {remarkPluginFrontmatter.readingTime} min read
              </p>
            </header>

            <TableOfContents headings={headings} />

            <div class="post-content">
              <Content />
            </div>

            <div class="end-mark">&#10022;</div>
          </article>

          {(prevPost || nextPost) && (
            <nav class="post-navigation">
              {prevPost ? (
                <a href={`/blog/${prevPost.slug}`} class="nav-link prev">
                  <span class="nav-direction">&larr; {post.data.series ? 'previous' : 'older'}</span>
                  <span class="nav-title">{prevPost.data.title}</span>
                </a>
              ) : <span />}
              {nextPost ? (
                <a href={`/blog/${nextPost.slug}`} class="nav-link next">
                  <span class="nav-direction">{post.data.series ? 'next' : 'newer'} &rarr;</span>
                  <span class="nav-title">{nextPost.data.title}</span>
                </a>
              ) : <span />}
            </nav>
          )}
        </div>
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  main {
    margin: 0;
    padding: 0;
  }

  /* ─── Shell session framing ─── */
  .shell-session {
    font-size: 14px;
    line-height: 1.5;
  }

  .shell-line {
    margin-bottom: 0.5rem;
  }

  .ps1 {
    font-weight: 700;
    margin-right: 0.5em;
  }

  .ps1-user { color: var(--term-green); }
  .ps1-sep  { color: var(--term-fg-dim); }
  .ps1-dir  { color: #818cf8; }
  .ps1-dollar { color: var(--term-muted); margin-left: 0.1em; }

  .shell-cmd {
    color: var(--term-fg);
  }

  /* ─── Post header ─── */
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--term-border);
  }

  .category-label {
    color: var(--term-muted);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    color: var(--term-accent);
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
    line-height: 1.3;
    text-shadow: var(--term-glow);
  }

  /* suppress global ::before on the post title h1 since it's not in .post-content */
  .post-header h1::before {
    content: "# ";
    color: var(--term-muted);
  }

  .post-meta {
    color: var(--term-muted);
    font-size: 13px;
    margin: 0;
  }

  /* ─── Post body ─── */
  .post-content {
    margin-top: 1.5rem;
    font-size: 15px;
    line-height: 1.75;
    color: var(--term-fg);
  }

  /* Headings in content — markdown style */
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    font-family: var(--font-mono);
    color: var(--term-accent);
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-content :global(h1)::before { content: "# ";    color: var(--term-muted); }
  .post-content :global(h2)::before { content: "## ";   color: var(--term-muted); }
  .post-content :global(h3)::before { content: "### ";  color: var(--term-muted); }
  .post-content :global(h4)::before { content: "#### "; color: var(--term-muted); }

  .post-content :global(h1) { font-size: 1.4rem; }
  .post-content :global(h2) { font-size: 1.25rem; }
  .post-content :global(h3) { font-size: 1.1rem; }
  .post-content :global(h4) { font-size: 1rem; }

  /* Paragraphs */
  .post-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.75;
    color: var(--term-fg);
  }

  /* Blockquotes */
  .post-content :global(blockquote) {
    position: relative;
    margin: 0 0 1.5rem 1.5rem;
    color: var(--term-fg-dim);
    font-style: italic;
  }

  .post-content :global(blockquote)::before {
    position: absolute;
    left: -1.5rem;
    content: ">";
    color: var(--term-muted);
    font-style: normal;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Inline */
  .post-content :global(em)     { color: var(--term-fg); font-style: italic; }
  .post-content :global(strong) { font-weight: 600; color: var(--term-fg-bright); }

  .post-content :global(code) {
    background: var(--term-code-bg);
    color: var(--term-accent);
    padding: 2px 5px;
    border-radius: 3px;
    font-size: 0.93em;
    font-family: var(--font-mono);
  }

  /* Lists */
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.25rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .post-content :global(ul li::marker) {
    content: '\203A\00A0';
    color: var(--term-muted);
  }

  .post-content :global(ol li::marker) {
    color: var(--term-muted);
  }

  /* HR */
  .post-content :global(hr) {
    border: 0;
    margin: 2.5rem 0;
  }

  .post-content :global(hr)::after {
    content: '---';
    color: var(--term-muted);
    display: block;
  }

  /* Links */
  .post-content :global(a) {
    color: var(--term-accent);
    text-decoration: none;
  }

  .post-content :global(a:hover) {
    color: var(--term-accent-hover);
    text-decoration: underline;
  }

  /* Images */
  .post-content :global(img) {
    max-width: 100%;
    border: 1px solid var(--term-border);
    border-radius: 4px;
  }

  /* ─── End mark ─── */
  .end-mark {
    text-align: center;
    font-size: 1rem;
    color: var(--term-muted);
    margin: 3rem 0 2rem;
    letter-spacing: 0.5em;
  }

  /* ─── Post nav ─── */
  .post-navigation {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--term-border);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    flex: 1;
    gap: 0.2rem;
  }

  .nav-link.next {
    text-align: right;
  }

  .nav-direction {
    font-size: 12px;
    color: var(--term-muted);
    font-family: var(--font-mono);
  }

  .nav-title {
    font-size: 13px;
    color: var(--term-fg-dim);
    font-family: var(--font-mono);
    line-height: 1.4;
  }

  .nav-link:hover .nav-title {
    color: var(--term-accent);
  }

  @media (max-width: 768px) {
    .post-navigation {
      flex-direction: column;
      gap: 1.5rem;
    }

    .nav-link.next {
      text-align: left;
    }
  }
</style>
