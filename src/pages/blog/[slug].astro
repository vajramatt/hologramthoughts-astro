---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );

  return sortedPosts.map((post, index) => {
    let prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    let nextPost = index > 0 ? sortedPosts[index - 1] : null;

    // If this post belongs to a series, use series order for prev/next
    if (post.data.series && post.data.seriesOrder !== undefined) {
      const seriesPosts = posts
        .filter(p => p.data.series === post.data.series && p.data.seriesOrder !== undefined)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
      const seriesIndex = seriesPosts.findIndex(p => p.slug === post.slug);
      prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
      nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
    }

    return {
      params: { slug: post.slug },
      props: { post, nextPost, prevPost },
    };
  });
}

const { post, nextPost, prevPost } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await post.render();

const dateStr = post.data.pubDate?.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const ogDescription = post.data.description
  ?? post.body
      .replace(/^---[\s\S]*?---\n?/, '')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/https?:\/\/\S+/g, '')
      .replace(/#+\s+/g, '')
      .replace(/\*\*(.*?)\*\*/g, '$1')
      .replace(/\*(.*?)\*/g, '$1')
      .replace(/`[^`]+`/g, '')
      .replace(/^\s*[-*+]\s+/gm, '')
      .replace(/\s{2,}/g, ' ')
      .replace(/\n+/g, ' ')
      .trim()
      .substring(0, 200)
      .replace(/\s+\S*$/, '') + '…';

const publishedTime = post.data.pubDate?.toISOString();
const canonicalUrl = `https://hologramthoughts.com/blog/${post.slug}/`;
---

<Layout
  title={`${post.data.title} — Hologram Thoughts`}
  description={ogDescription}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
>
  <ReadingProgress />
  <div class="page">
    <SiteHeader activePage="home" />

    <main class="page-main">
      <article class="post">

        <header class="post-header">
          {post.data.categories?.length > 0 && (
            <p class="eyebrow">{post.data.categories.join(' · ')}</p>
          )}
          <h1 class="post-title">{post.data.title}</h1>
          {post.data.description && (
            <p class="post-dek">{post.data.description}</p>
          )}
          <p class="post-byline">
            <time datetime={publishedTime}>{dateStr}</time>
            <span class="byline-sep">·</span>
            <span>{remarkPluginFrontmatter.readingTime} min read</span>
            {post.data.series && (
              <>
                <span class="byline-sep">·</span>
                <span class="series-label">
                  <em>{post.data.series}</em>{post.data.seriesOrder ? `, pt. ${post.data.seriesOrder}` : ''}
                </span>
              </>
            )}
          </p>
        </header>

        <TableOfContents headings={headings} />

        <div class="post-body">
          <Content />
        </div>

        <div class="end-mark" aria-hidden="true">✦</div>

        {(prevPost || nextPost) && (
          <nav class="post-nav" aria-label="Post navigation">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}`} class="nav-link prev">
                <span class="nav-direction">{post.data.series ? '← previous' : '← older'}</span>
                <span class="nav-title">{prevPost.data.title}</span>
              </a>
            ) : <span class="nav-spacer" />}
            {nextPost ? (
              <a href={`/blog/${nextPost.slug}`} class="nav-link next">
                <span class="nav-direction">{post.data.series ? 'next →' : 'newer →'}</span>
                <span class="nav-title">{nextPost.data.title}</span>
              </a>
            ) : <span class="nav-spacer" />}
          </nav>
        )}
      </article>
    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .post {
    max-width: var(--measure);
    margin: 0 auto;
    padding-top: 2rem;
  }

  /* ═══════════════════════════════════════════════════════
     POST HEADER — editorial opening
     ═══════════════════════════════════════════════════════ */
  .post-header {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 40;
    font-weight: 500;
    font-size: clamp(2rem, 1.3rem + 2.6vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--fg-bright);
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .post-dek {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--fg-dim);
    margin: 0 0 1.5rem;
    text-wrap: pretty;
    max-width: 34rem;
  }

  .post-byline {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .post-byline .byline-sep {
    color: var(--rule);
    margin: 0 0.5em;
  }

  .series-label em {
    font-style: italic;
    color: var(--fg-dim);
  }

  /* ═══════════════════════════════════════════════════════
     POST BODY — the reading column
     Fraunces for signposts, Newsreader for prose.
     ═══════════════════════════════════════════════════════ */
  .post-body {
    font-family: var(--font-body);
    font-size: var(--size-body);
    line-height: 1.75;
    color: var(--fg);
    font-feature-settings: "kern", "liga", "onum" 1;
    hanging-punctuation: first last;
  }

  /* Opening paragraph — slightly larger, first line in small caps.
     Classic magazine lead. Works regardless of paragraph length,
     no float = no layout gotchas on short openings. */
  .post-body :global(> p:first-of-type) {
    font-size: 1.08em;
    margin-top: 0;
  }

  .post-body :global(> p:first-of-type::first-line) {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 40, "wght" 500;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.1em;
    color: var(--fg-bright);
  }

  /* Paragraphs */
  .post-body :global(p) {
    margin: 0 0 1.25em;
    text-wrap: pretty;
  }

  /* Headings inside posts — Fraunces signposts */
  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(h6) {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72, "SOFT" 50;
    font-weight: 500;
    color: var(--fg-bright);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 2.5em 0 0.65em;
    text-wrap: balance;
  }

  .post-body :global(h1) { font-size: 1.7em; }
  .post-body :global(h2) { font-size: 1.45em; }
  .post-body :global(h3) { font-size: 1.25em; font-style: italic; }
  .post-body :global(h4) { font-size: 1.1em; color: var(--fg-dim); }

  /* Links — subtle underline at rest, clean hover */
  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 30%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 150ms ease, text-decoration-color 150ms ease;
  }

  .post-body :global(a:hover) {
    color: var(--accent-hover);
    text-decoration-color: currentColor;
  }

  /* Emphasis */
  .post-body :global(em)     { font-style: italic; color: var(--fg); }
  .post-body :global(strong) { font-weight: 600;   color: var(--fg-bright); }

  /* Blockquote — literary pulled indent */
  .post-body :global(blockquote) {
    margin: 1.75em 0 1.75em -0.5rem;
    padding: 0.1em 0 0.1em 1.5rem;
    border-left: 2px solid var(--accent);
    font-style: italic;
    color: var(--fg-dim);
    font-size: 1.02em;
  }

  .post-body :global(blockquote p) {
    margin-bottom: 0.5em;
  }

  .post-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Inline code — mono, smaller, subtle bg */
  .post-body :global(code) {
    font-family: var(--font-mono);
    background: var(--code-bg);
    color: var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 0.82em;
  }

  /* Code blocks */
  .post-body :global(pre) {
    font-family: var(--font-mono);
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin: 1.5em 0;
    overflow-x: auto;
    font-size: 0.85em;
    line-height: 1.55;
  }

  .post-body :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Lists */
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.25em;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4em;
  }

  /* HR — three quiet dots */
  .post-body :global(hr) {
    border: 0;
    margin: 2.5em 0;
    text-align: center;
  }

  .post-body :global(hr)::after {
    content: "· · ·";
    color: var(--muted);
    letter-spacing: 0.6em;
    font-size: 0.9rem;
  }

  /* Images */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 1.5em 0;
    display: block;
  }

  .post-body :global(figure) {
    margin: 2em 0;
  }

  .post-body :global(figcaption) {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
    margin-top: 0.75em;
  }

  /* ═══════════════════════════════════════════════════════
     END MARK
     ═══════════════════════════════════════════════════════ */
  .end-mark {
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--accent);
    opacity: 0.65;
    margin: 3rem 0 2.5rem;
    letter-spacing: 0;
  }

  /* ═══════════════════════════════════════════════════════
     POST NAV
     ═══════════════════════════════════════════════════════ */
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .nav-spacer { flex: 1; }

  .nav-link {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    color: inherit;
  }

  .nav-link.next { text-align: right; }

  .nav-direction {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.02em;
    font-style: italic;
  }

  .nav-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 40;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--fg-dim);
    transition: color 150ms ease;
  }

  .nav-link:hover .nav-title {
    color: var(--accent);
  }

  @media (max-width: 36rem) {
    .post-nav {
      flex-direction: column;
      gap: 1.5rem;
    }
    .nav-link.next { text-align: left; }
  }

</style>
