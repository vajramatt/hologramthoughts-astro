---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ThemeChipStrip from '../../components/ThemeChipStrip.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import type { PostSidecar } from '../../lib/themes';
import { blogPostingGraph } from '../../utils/jsonld';
import { categoryColor } from '../../utils/category-color';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );

  return sortedPosts.map((post, index) => {
    let prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    let nextPost = index > 0 ? sortedPosts[index - 1] : null;

    // If this post belongs to a series, use series order for prev/next
    if (post.data.series && post.data.seriesOrder !== undefined) {
      const seriesPosts = posts
        .filter(p => p.data.series === post.data.series && p.data.seriesOrder !== undefined)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
      const seriesIndex = seriesPosts.findIndex(p => p.slug === post.slug);
      prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
      nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
    }

    return {
      params: { slug: post.slug },
      props: { post, nextPost, prevPost },
    };
  });
}

const { post, nextPost, prevPost } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await post.render();

let sidecar: PostSidecar = { slug: '', themeIds: [], related: [] };
try {
  const slug = post.data.slug ?? post.slug;
  sidecar = (await import(`../../content/themes/${slug}.json`)).default;
} catch { /* no sidecar */ }

const dateStr = post.data.pubDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});

const ogDescription = post.data.description
  ?? post.body
      .replace(/^---[\s\S]*?---\n?/, '')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/https?:\/\/\S+/g, '')
      .replace(/#+\s+/g, '')
      .replace(/\*\*(.*?)\*\*/g, '$1')
      .replace(/\*(.*?)\*/g, '$1')
      .replace(/`[^`]+`/g, '')
      .replace(/^\s*[-*+]\s+/gm, '')
      .replace(/\s{2,}/g, ' ')
      .replace(/\n+/g, ' ')
      .trim()
      .substring(0, 200)
      .replace(/\s+\S*$/, '') + '…';

const publishedTime = post.data.pubDate?.toISOString();
const canonicalUrl = `https://hologramthoughts.com/blog/${post.slug}/`;
const readingTime = remarkPluginFrontmatter?.readingTime;
const isSeries = !!post.data.series;
const jsonLd = blogPostingGraph({
  title: post.data.title,
  description: ogDescription,
  url: canonicalUrl,
  datePublished: publishedTime!,
  image: 'https://hologramthoughts.com/og-image.png',
  tags: post.data.tags,
  categories: post.data.categories,
  wordCount: remarkPluginFrontmatter?.wordCount ?? post.data.wordCount,
  readingTime,
});
---

<Layout
  title={`${post.data.title} — Hologram Thoughts`}
  description={ogDescription}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <ReadingProgress />

  <!-- Applies the saved scale before the prose paints, so a resized reader never sees a size flash -->
  <script is:inline>
    (() => {
      try {
        const v = parseFloat(localStorage.getItem('ht-story-scale') || '');
        if (v >= 0.9 && v <= 1.6) document.documentElement.style.setProperty('--story-scale', String(v));
      } catch {}
    })();
  </script>

  <article>
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-3">
        <span style="color: var(--color-amber-bright)">{dateStr}</span>
        {readingTime && <span> · <span style="color: var(--color-amber-bright)">{readingTime} min</span></span>}
        {post.data.categories && post.data.categories.length > 0 && post.data.categories.map(c => (
          <span> · <span style={`color: ${categoryColor(c)}`}>{c}</span></span>
        ))}
      </p>
      <h1 class="text-5xl md:text-6xl tracking-tight leading-[1.05]" style="font-family: var(--font-display); font-weight: 600; color: var(--color-magenta-hot);">{post.data.title}</h1>
      <div class="mt-4 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
        <p class="text-sm text-[var(--color-ink-soft)]" style="font-family: var(--font-ui);">
          by <span style="color: var(--color-cyan)">Matthew Williamson</span>
        </p>
        <div class="story-scale" role="group" aria-label="Story text size">
          <button type="button" data-scale="dec" aria-label="Decrease story text size">A−</button>
          <button type="button" data-scale="reset" aria-label="Reset story text size" data-scale-readout>100%</button>
          <button type="button" data-scale="inc" aria-label="Increase story text size">A+</button>
        </div>
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div class="prose post-content">
      <Content />
    </div>

    <ThemeChipStrip themeIds={sidecar.themeIds} />
    <RelatedPosts related={sidecar.related} />
  </article>

  {(prevPost || nextPost) && (
    <nav class="mt-16 pt-8 border-t border-[var(--color-border-strong)] grid md:grid-cols-2 gap-6">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="group no-underline block">
          <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">
            {isSeries ? '← Previous' : '← Older'}
          </p>
          <p class="text-[var(--color-ink)] group-hover:text-[var(--color-cyan)] transition-colors" style="font-family: var(--font-display);">{prevPost.data.title}</p>
        </a>
      ) : <span />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="group no-underline block md:text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-1">
            {isSeries ? 'Next →' : 'Newer →'}
          </p>
          <p class="text-[var(--color-ink)] group-hover:text-[var(--color-cyan)] transition-colors" style="font-family: var(--font-display);">{nextPost.data.title}</p>
        </a>
      ) : <span />}
    </nav>
  )}
</Layout>

<style>
  /* --story-scale is the reader-set text size (A− / A+ control); headings use em so they scale with it */
  .post-content {
    font-size: calc(1.0625rem * var(--story-scale, 1));
    line-height: 1.75;
    color: var(--color-ink);
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-weight: 480;
    letter-spacing: -0.015em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .post-content :global(h1) { font-size: 1.882em; }
  .post-content :global(h2) { font-size: 1.553em; }
  .post-content :global(h3) { font-size: 1.271em; }
  .post-content :global(h4) { font-size: 1.082em; }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.75;
  }

  .post-content :global(blockquote) {
    margin: 1.5rem 0 1.5rem 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--color-border-strong);
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(em)     { font-style: italic; }
  .post-content :global(strong) { font-weight: 600; }

  .post-content :global(code) {
    background: color-mix(in oklch, var(--color-cyan) 12%, transparent);
    color: var(--color-amber-bright);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: var(--font-mono);
    border: 1px solid var(--color-border);
  }

  .post-content :global(pre) {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .post-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border-strong);
    margin: 2.5rem 0;
  }

  .post-content :global(a) {
    color: var(--color-amber-bright);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-grow);
  }

  .post-content :global(a:hover) {
    color: var(--color-cyan);
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5rem 0;
  }

  .story-scale {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-soft);
  }

  .story-scale button {
    background: none;
    border: none;
    font: inherit;
    color: inherit;
    padding: 0.3rem 0.55rem;
    border-radius: 6px;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-grow), background var(--dur-fast) var(--ease-grow);
  }

  .story-scale button:hover {
    color: var(--color-cyan);
    background: color-mix(in oklch, var(--color-cyan) 10%, transparent);
  }

  .story-scale [data-scale-readout] {
    min-width: 3.4em;
    text-align: center;
    color: var(--color-amber-bright);
  }

  @media print {
    .story-scale { display: none; }
  }
</style>

<script>
  const KEY = 'ht-story-scale';
  const MIN = 0.9, MAX = 1.6, STEP = 0.1;
  let scale = 1;
  try {
    const saved = parseFloat(localStorage.getItem(KEY) || '');
    if (saved >= MIN && saved <= MAX) scale = saved;
  } catch {}

  const readout = document.querySelector('[data-scale-readout]');

  function apply() {
    scale = Math.min(MAX, Math.max(MIN, Math.round(scale * 10) / 10));
    document.documentElement.style.setProperty('--story-scale', String(scale));
    if (readout) readout.textContent = `${Math.round(scale * 100)}%`;
    try { localStorage.setItem(KEY, String(scale)); } catch {}
  }

  document.querySelectorAll<HTMLButtonElement>('[data-scale]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.scale;
      if (action === 'inc') scale += STEP;
      else if (action === 'dec') scale -= STEP;
      else scale = 1;
      apply();
    });
  });

  if (readout && scale !== 1) readout.textContent = `${Math.round(scale * 100)}%`;
</script>
