---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const searchablePosts = allPosts.map(post => ({
  title: post.data.title,
  url: `/blog/${post.slug}`,
  categories: post.data.categories || [],
  description: post.data.description || '',
  content: post.body.substring(0, 600),
  date: post.data.pubDate
}));
---

<Layout title="Search — Hologram Thoughts">
  <div class="page">
    <SiteHeader activePage="search" />

    <main class="page-main search">
      <header class="page-header">
        <p class="eyebrow">Search</p>
        <h1>Looking for something in particular?</h1>
      </header>

      <div class="search-box">
        <label for="search-input" class="visually-hidden">Search the archive</label>
        <input
          type="search"
          id="search-input"
          placeholder="buddhism, dreams, emptiness…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <div id="search-results" class="search-results"></div>

      <aside class="search-tips">
        <p class="tips-label">Try —</p>
        <ul>
          <li><em>topics</em> — buddhism, meditation, chenrezig</li>
          <li><em>stories</em> — fiction, emergence, jyoti, the willow</li>
          <li><em>concepts</em> — oneness, dharma, enlightenment</li>
          <li><em>practices</em> — reiki, yoga, mindfulness</li>
        </ul>
      </aside>
    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .search {
    max-width: var(--measure);
    margin: 0 auto;
  }

  .page-header { margin: 1rem 0 2rem; }

  .eyebrow {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "SOFT" 40;
    font-weight: 500;
    font-size: clamp(1.75rem, 1.3rem + 1.6vw, 2.35rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--fg-bright);
  }

  .search-box {
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--rule);
    transition: border-color 200ms ease;
  }

  .search-box:focus-within {
    border-bottom-color: var(--accent);
  }

  .search-box input[type="search"] {
    width: 100%;
    border: none;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.5;
    padding: 0.75rem 0.25rem;
    outline: none;
    -webkit-appearance: none;
  }

  .search-box input::placeholder {
    color: var(--muted);
    font-style: italic;
    opacity: 0.9;
  }

  .search-results { margin-bottom: 2rem; }

  /* JS-generated results */
  :global(.results-count) {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1rem;
    letter-spacing: 0.01em;
  }

  :global(.search-result) {
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
  }

  :global(.search-result:last-child) { border-bottom: none; }

  :global(.search-result-title) {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 40;
    font-weight: 500;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  :global(.search-result-title a) {
    color: var(--fg-bright);
    text-decoration: none;
    transition: color 150ms ease;
  }

  :global(.search-result-title a:hover) { color: var(--accent); }

  :global(.search-result-excerpt) {
    font-family: var(--font-body);
    color: var(--fg-dim);
    line-height: 1.5;
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
  }

  :global(.search-result-categories) {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  :global(.category-tag) {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--muted);
    font-size: 0.8rem;
  }

  :global(.no-results) {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--muted);
    padding: 1rem 0;
  }

  /* Tips */
  .search-tips {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body);
    color: var(--fg-dim);
    font-size: 0.95rem;
  }

  .tips-label {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "SOFT" 30;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .search-tips ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .search-tips li {
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }

  .search-tips em {
    color: var(--muted);
    font-style: italic;
    margin-right: 0.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    overflow: hidden; clip: rect(0,0,0,0);
    border: 0;
  }
</style>

<script define:vars={{ searchablePosts }}>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');

    function performSearch(query) {
      if (query.length < 2) {
        searchResults.textContent = '';
        return;
      }

      const lowerQuery = query.toLowerCase();
      const results = searchablePosts.filter(post =>
        post.title.toLowerCase().includes(lowerQuery) ||
        post.description.toLowerCase().includes(lowerQuery) ||
        post.categories.some(cat => cat.toLowerCase().includes(lowerQuery)) ||
        post.content.toLowerCase().includes(lowerQuery)
      );

      results.sort((a, b) => {
        const aInTitle = a.title.toLowerCase().includes(lowerQuery);
        const bInTitle = b.title.toLowerCase().includes(lowerQuery);
        if (aInTitle && !bInTitle) return -1;
        if (!aInTitle && bInTitle) return 1;
        return new Date(b.date) - new Date(a.date);
      });

      searchResults.textContent = '';

      const countEl = document.createElement('div');
      countEl.className = 'results-count';
      countEl.textContent = results.length + ' result' + (results.length !== 1 ? 's' : '');
      searchResults.appendChild(countEl);

      if (results.length === 0) {
        const none = document.createElement('div');
        none.className = 'no-results';
        none.textContent = 'no matches for "' + query + '"';
        searchResults.appendChild(none);
        return;
      }

      const list = document.createElement('div');
      list.className = 'results-list';

      results.slice(0, 25).forEach(result => {
        const article = document.createElement('article');
        article.className = 'search-result';

        const titleEl = document.createElement('p');
        titleEl.className = 'search-result-title';
        const link = document.createElement('a');
        link.href = result.url;
        link.textContent = result.title;
        titleEl.appendChild(link);
        article.appendChild(titleEl);

        const excerpt = document.createElement('p');
        excerpt.className = 'search-result-excerpt';
        excerpt.textContent = result.description || '';
        article.appendChild(excerpt);

        if (result.categories.length > 0) {
          const cats = document.createElement('div');
          cats.className = 'search-result-categories';
          result.categories.forEach(cat => {
            const tag = document.createElement('span');
            tag.className = 'category-tag';
            tag.textContent = cat;
            cats.appendChild(tag);
          });
          article.appendChild(cats);
        }

        list.appendChild(article);
      });

      searchResults.appendChild(list);
    }

    let debounceTimer;
    searchInput.addEventListener('input', function(e) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => performSearch(e.target.value.trim()), 250);
    });

    searchInput.focus();
  });
</script>
