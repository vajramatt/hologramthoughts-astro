---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const searchablePosts = allPosts.map(post => ({
  title: post.data.title,
  url: `/blog/${post.slug}`,
  categories: post.data.categories || [],
  description: post.data.description || '',
  content: post.body.substring(0, 500),
  date: post.data.pubDate
}));
---

<Layout title="Search - Hologram Thoughts">
  <SiteHeader activePage="search" />

  <main>
    <div class="terminal-main">
      <div class="shell-session">
        <div class="shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd">grep -r "" posts/</span>
        </div>

        <div class="shell-output search-area">
          <div class="searchbox">
            <span class="search-prefix">pattern: </span>
            <input type="search" id="search-input" placeholder="buddhism, dreams, emptiness..." autocomplete="off">
          </div>
          <div id="search-results"></div>
        </div>

        <div class="shell-output tips-area">
          <p class="tips-header"># search tips</p>
          <p>topics: "buddhism", "meditation", "chenrezig"</p>
          <p>stories: "fiction", "emergence", "jyoti"</p>
          <p>concepts: "oneness", "dharma", "enlightenment"</p>
          <p>practices: "reiki", "yoga", "mindfulness"</p>
        </div>
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  main { margin: 0; padding: 0; min-height: 70vh; }

  .shell-session { font-size: 14px; line-height: 1.5; }
  .shell-line { margin-bottom: 0.5rem; }

  .ps1 { font-weight: 700; margin-right: 0.5em; }
  .ps1-user   { color: var(--term-green); }
  .ps1-sep    { color: var(--term-fg-dim); }
  .ps1-dir    { color: #818cf8; }
  .ps1-dollar { color: var(--term-muted); margin-left: 0.1em; }
  .shell-cmd  { color: var(--term-fg-dim); }

  .shell-output { color: var(--term-fg-dim); margin-bottom: 1rem; }

  /* Search input */
  .searchbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--term-border);
    border-radius: 4px;
    padding: 8px 12px;
    background: var(--term-code-bg);
    max-width: 520px;
  }

  .search-prefix {
    color: var(--term-muted);
    white-space: nowrap;
    font-size: 13px;
  }

  .searchbox input[type="search"] {
    border: none;
    background: transparent;
    color: var(--term-fg);
    font-family: var(--font-mono);
    font-size: 14px;
    outline: none;
    width: 100%;
    -webkit-appearance: none;
  }

  .searchbox input[type="search"]::placeholder {
    color: var(--term-muted);
    opacity: 0.7;
  }

  .searchbox:focus-within {
    border-color: var(--term-accent);
  }

  #search-results { margin-bottom: 1rem; }

  /* Tips */
  .tips-area p {
    margin: 0.15rem 0;
    font-size: 13px;
    color: var(--term-muted);
  }

  .tips-header {
    color: var(--term-fg-dim) !important;
    margin-bottom: 0.25rem !important;
  }

  /* JS-generated results */
  :global(.results-count) {
    color: var(--term-muted);
    font-size: 12px;
    margin-bottom: 1rem;
  }

  :global(.search-result) {
    padding: 8px 0;
    border-bottom: 1px dashed var(--term-border);
  }

  :global(.search-result:last-child) {
    border-bottom: none;
  }

  :global(.search-result-title) {
    margin: 0 0 0.25rem;
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  :global(.search-result-title a) {
    color: var(--term-accent);
    text-decoration: none;
  }

  :global(.search-result-title a:hover) {
    color: var(--term-accent-hover);
  }

  :global(.search-result-excerpt) {
    color: var(--term-fg-dim);
    line-height: 1.5;
    margin: 0 0 0.25rem;
    font-size: 12px;
  }

  :global(.search-result-categories) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.category-tag) {
    color: var(--term-muted);
    font-size: 11px;
  }

  :global(.no-results) {
    color: var(--term-muted);
    font-size: 13px;
    padding: 1rem 0;
  }
</style>

<script define:vars={{ searchablePosts }}>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');

    function esc(str) {
      const d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    function performSearch(query) {
      if (query.length < 2) {
        searchResults.textContent = '';
        return;
      }

      const lowerQuery = query.toLowerCase();
      const results = searchablePosts.filter(post =>
        post.title.toLowerCase().includes(lowerQuery) ||
        post.description.toLowerCase().includes(lowerQuery) ||
        post.categories.some(cat => cat.toLowerCase().includes(lowerQuery)) ||
        post.content.toLowerCase().includes(lowerQuery)
      );

      results.sort((a, b) => {
        const aInTitle = a.title.toLowerCase().includes(lowerQuery);
        const bInTitle = b.title.toLowerCase().includes(lowerQuery);
        if (aInTitle && !bInTitle) return -1;
        if (!aInTitle && bInTitle) return 1;
        return new Date(b.date) - new Date(a.date);
      });

      // Build DOM nodes safely — no raw HTML injection from user input
      searchResults.textContent = '';

      const countEl = document.createElement('div');
      countEl.className = 'results-count';
      countEl.textContent = results.length + ' result' + (results.length !== 1 ? 's' : '');
      searchResults.appendChild(countEl);

      if (results.length === 0) {
        const none = document.createElement('div');
        none.className = 'no-results';
        none.textContent = 'no results for "' + query + '"';
        searchResults.appendChild(none);
        return;
      }

      const list = document.createElement('div');
      list.className = 'results-list';

      results.slice(0, 20).forEach(result => {
        const article = document.createElement('article');
        article.className = 'search-result';

        const titleEl = document.createElement('p');
        titleEl.className = 'search-result-title';
        const link = document.createElement('a');
        link.href = result.url;
        link.textContent = result.title;
        titleEl.appendChild(link);
        article.appendChild(titleEl);

        const excerpt = document.createElement('p');
        excerpt.className = 'search-result-excerpt';
        excerpt.textContent = result.description || 'click to read...';
        article.appendChild(excerpt);

        if (result.categories.length > 0) {
          const cats = document.createElement('div');
          cats.className = 'search-result-categories';
          result.categories.forEach(cat => {
            const tag = document.createElement('span');
            tag.className = 'category-tag';
            tag.textContent = '# ' + cat;
            cats.appendChild(tag);
          });
          article.appendChild(cats);
        }

        list.appendChild(article);
      });

      searchResults.appendChild(list);
    }

    let debounceTimer;
    searchInput.addEventListener('input', function(e) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => performSearch(e.target.value.trim()), 300);
    });

    searchInput.focus();
  });
</script>
