---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

function getExcerpt(body, maxLength = 120) {
  const text = body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/#+\s+/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/---/g, '')
    .replace(/\s{2,}/g, ' ')
    .replace(/\n+/g, ' ')
    .trim();
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).replace(/\s+\S*$/, '') + '…';
}

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );
  return paginate(sortedPosts, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`Archive${page.currentPage > 1 ? ` - Page ${page.currentPage}` : ''} - Hologram Thoughts`}>
  <SiteHeader activePage="archive" />

  <main>
    <div class="terminal-main">
      <div class="shell-session">
        <div class="shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@samsara</span><span class="ps1-sep">:</span><span class="ps1-dir">~/dharma</span><span class="ps1-dollar"> →</span>
          </span>
          <span class="shell-cmd">ls -lt posts/ &nbsp;# {page.total} posts</span>
        </div>

        <div class="shell-output">
          <div class="posts-list">
            {page.data.map(post => (
              <div class="post-entry">
                <div class="post-entry-header">
                  <span class="post-date">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: '2-digit',
                      day: '2-digit'
                    })}
                  </span>
                  <a href={`/blog/${post.slug}`} class="post-title">{post.data.title}</a>
                </div>
                <p class="post-excerpt">{getExcerpt(post.body)}</p>
              </div>
            ))}
          </div>

          <nav class="pagination">
            {page.url.prev ? (
              <a href={page.url.prev} class="page-link">&larr; newer</a>
            ) : <span />}
            <span class="page-info">page {page.currentPage}/{page.lastPage}</span>
            {page.url.next ? (
              <a href={page.url.next} class="page-link">older &rarr;</a>
            ) : <span />}
          </nav>
        </div>
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  main { margin: 0; padding: 0; }

  .shell-session { font-size: 14px; line-height: 1.5; }
  .shell-line { margin-bottom: 0.5rem; }

  .ps1 { font-weight: 700; margin-right: 0.5em; }
  .ps1-user   { color: var(--term-green); }
  .ps1-sep    { color: var(--term-fg-dim); }
  .ps1-dir    { color: #818cf8; }
  .ps1-dollar { color: var(--term-muted); margin-left: 0.1em; }
  .shell-cmd  { color: var(--term-fg-dim); }

  .shell-output { color: var(--term-fg-dim); }

  .posts-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 2rem;
  }

  .post-entry {
    padding: 8px 0;
    border-bottom: 1px dashed var(--term-border);
  }

  .post-entry:last-child { border-bottom: none; }

  .post-entry-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3px;
  }

  .post-date {
    color: var(--term-muted);
    font-size: 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-title {
    color: var(--term-accent);
    text-decoration: none;
    font-weight: 600;
    line-height: 1.4;
  }

  .post-title:hover { color: var(--term-accent-hover); }

  .post-excerpt {
    color: var(--term-fg-dim);
    font-size: 12px;
    line-height: 1.5;
    margin: 0;
    padding-left: calc(10ch + 1rem);
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--term-border);
  }

  .page-link {
    color: var(--term-accent);
    text-decoration: none;
    font-size: 13px;
  }

  .page-link:hover { color: var(--term-accent-hover); }

  .page-info {
    color: var(--term-muted);
    font-size: 12px;
  }
</style>
