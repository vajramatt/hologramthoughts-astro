---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

function getExcerpt(body: string, maxLength = 160) {
  const text = body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/#+\s+/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/---/g, '')
    .replace(/\s{2,}/g, ' ')
    .replace(/\n+/g, ' ')
    .trim();
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).replace(/\s+\S*$/, '') + '…';
}

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort((a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );
  return paginate(sortedPosts, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const slugOf = (p: any) => p.data.slug ?? p.slug;

// Load sidecars for posts on this page
const themeIdsBySlug: Record<string, string[]> = {};
for (const p of page.data) {
  const s = slugOf(p);
  try {
    const sc = await import(`../../content/themes/${s}.json`);
    themeIdsBySlug[s] = sc.default.themeIds ?? [];
  } catch {
    themeIdsBySlug[s] = [];
  }
}
---

<Layout title={`Archive${page.currentPage > 1 ? ` — Page ${page.currentPage}` : ''} — Hologram Thoughts`}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-2">Archive</p>
    <h1 class="text-5xl tracking-tight" style="font-family: var(--font-display);">All posts</h1>
    <p class="text-[var(--color-ink-soft)] mt-3">
      {page.total} posts, newest first.
    </p>
  </header>

  <section class="space-y-2">
    {page.data.map((post: any) => {
      const s = slugOf(post);
      return (
        <PostCard
          slug={s}
          title={post.data.title}
          pubDate={post.data.pubDate}
          excerpt={getExcerpt(post.body)}
          themeIds={themeIdsBySlug[s]}
        />
      );
    })}
  </section>

  <nav class="flex justify-between items-center mt-12 pt-8 border-t border-[var(--color-border-strong)] text-sm">
    {page.url.prev ? (
      <a href={page.url.prev} class="no-underline px-4 py-2 rounded-full border border-[var(--color-border-strong)] hover:bg-[color-mix(in_oklch,var(--color-spore)_8%,transparent)] hover:border-[var(--color-bioluminescent)] transition-all">
        Newer
      </a>
    ) : <span />}
    <span class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
      Page {page.currentPage} of {page.lastPage}
    </span>
    {page.url.next ? (
      <a href={page.url.next} class="no-underline px-4 py-2 rounded-full border border-[var(--color-border-strong)] hover:bg-[color-mix(in_oklch,var(--color-spore)_8%,transparent)] hover:border-[var(--color-bioluminescent)] transition-all">
        Older
      </a>
    ) : <span />}
  </nav>
</Layout>
