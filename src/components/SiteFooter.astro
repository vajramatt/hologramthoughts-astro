---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const oldestPost = allPosts.reduce((oldest, post) => {
  return !oldest || post.data.pubDate < oldest.data.pubDate ? post : oldest;
}, null);

const startYear = oldestPost ? oldestPost.data.pubDate.getFullYear() : new Date().getFullYear();
const currentYear = new Date().getFullYear();
const yearRange = startYear === currentYear ? currentYear : `${startYear}–${currentYear}`;
---

<footer class="site-footer">
  <div class="footer-mark" aria-hidden="true">☸</div>
  <p class="footer-line">
    <span>&copy; {yearRange} <a href="https://vajramatt.github.io/">Matthew Williamson</a></span>
    <span class="footer-sep">·</span>
    <a href="/rss.xml">feed</a>
    <span class="footer-sep">·</span>
    <a href="/archive">archive</a>
    <span class="footer-sep">·</span>
    <a href="/search">search</a>
  </p>
</footer>

<style>
  .site-footer {
    padding: 3rem 0 2.5rem;
    margin-top: 3rem;
    border-top: 1px solid var(--rule);
    text-align: center;
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 0.85rem;
  }

  .footer-mark {
    color: var(--muted);
    font-size: 1rem;
    margin-bottom: 0.75rem;
    opacity: 0.6;
  }

  .footer-line {
    margin: 0;
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    align-items: baseline;
  }

  .footer-sep {
    color: var(--rule);
  }

  .site-footer a {
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .site-footer a:hover {
    color: var(--accent);
  }
</style>
