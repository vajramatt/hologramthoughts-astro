---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const oldestPost = allPosts.reduce((oldest, post) => {
  return !oldest || post.data.pubDate < oldest.data.pubDate ? post : oldest;
}, null);

const startYear = oldestPost ? oldestPost.data.pubDate.getFullYear() : new Date().getFullYear();
const currentYear = new Date().getFullYear();
const yearRange = startYear === currentYear ? currentYear : `${startYear}-${currentYear}`;
---

<footer class="terminal-footer">
  <span>&copy; {yearRange} <a href="https://vajramatt.github.io/">Matthew Williamson</a> — hologram-thoughts</span>
  <span class="footer-homage">theme: an homage to <a href="https://blog.rice.is">rice</a></span>
  <nav class="footer-nav">
    <a href="/rss.xml">rss</a>
    <a href="/archive">archive</a>
    <a href="/search">search</a>
  </nav>
</footer>

<style>
  .terminal-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--term-border);
    color: var(--term-muted);
    font-size: 13px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px 16px;
    font-family: var(--font-mono);
  }

  .terminal-footer a:link,
  .terminal-footer a:visited {
    color: var(--term-fg-dim);
  }

  .terminal-footer a:hover {
    color: var(--term-fg-bright);
  }

  .footer-nav {
    display: flex;
    gap: 16px;
  }
</style>
