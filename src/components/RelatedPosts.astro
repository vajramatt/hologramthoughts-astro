---
import { getCollection } from 'astro:content';
import type { RelatedPost } from '../lib/themes';

interface Props { related: RelatedPost[]; }
const { related } = Astro.props;

const all = await getCollection('blog', ({ data }) => !data.draft);
// Build multi-key index: frontmatter slug, astro slug, and id (with/without .md)
// to tolerate any of those being how related[].slug was generated.
const bySlug = new Map();
for (const p of all) {
  const idBase = p.id.replace(/\.md$/, '');
  if (p.data.slug) bySlug.set(p.data.slug, p);
  if ((p as any).slug) bySlug.set((p as any).slug, p);
  bySlug.set(idBase, p);
}
const items = related
  .map(r => ({ post: bySlug.get(r.slug), rationale: r.rationale, slug: r.slug }))
  .filter(x => x.post);
---
{items.length > 0 && (
  <aside class="mt-12 pt-8 border-t border-[var(--color-border-strong)]">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-magenta)] mb-4">If this landed, <abbr title="Mycelial Underground Synthesis Editor" class="no-underline border-b border-dotted border-[var(--color-border-strong)] cursor-help hover:border-[var(--color-cyan)]">Muse</abbr> suggests</p>
    <ul class="space-y-5">
      {items.map(({ post, rationale }) => (
        <li>
          <a href={`/blog/${(post as any).slug ?? post!.id.replace(/\.md$/, '')}/`} class="block group no-underline">
            <p class="text-[var(--color-ink)] group-hover:text-[var(--color-cyan)] transition-colors" style="font-family: var(--font-display);">
              {post!.data.title}
              <span class="text-xs text-[var(--color-ink-soft)] ml-2 align-middle">({new Date(post!.data.pubDate).getUTCFullYear()})</span>
            </p>
            <p class="text-sm text-[var(--color-ink-soft)] mt-1 italic">{rationale}</p>
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}
