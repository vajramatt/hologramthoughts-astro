---
// Terminal main content wrapper — provides padding inside the terminal window.
---

<div class="terminal-main">
  <slot />
</div>

<style>
  .terminal-main {
    padding: 32px 56px;
    overflow-wrap: break-word;
    min-width: 0;
    overflow-x: hidden;
  }

  @media (max-width: 72rem) {
    .terminal-main {
      padding: 28px 40px;
    }
  }

  @media (max-width: 50rem) {
    .terminal-main {
      padding: 20px 24px;
    }
  }
</style>
