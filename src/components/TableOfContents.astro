---
interface Props {
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { headings } = Astro.props;
const showTOC = headings && headings.length > 1;
---

{showTOC && (
  <div class="toc">
    <div class="toc-header">### Contents</div>
    <nav class="toc-nav">
      <ul>
        {headings.map((heading) => (
          <li class={`toc-level-${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<style>
  .toc {
    border: 1px solid var(--term-border);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0 2.5rem;
    background: var(--term-code-bg);
    font-size: 14px;
  }

  .toc-header {
    color: var(--term-muted);
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  .toc-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-nav li {
    margin: 0.3rem 0;
  }

  .toc-nav a {
    color: var(--term-fg-dim);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    transition: color 0.15s;
    display: block;
    padding: 0.1rem 0;
  }

  .toc-nav a::before {
    content: "› ";
    color: var(--term-muted);
  }

  .toc-nav a:hover {
    color: var(--term-accent);
  }

  .toc-level-2 { padding-left: 1rem; }
  .toc-level-3 { padding-left: 2rem; }
  .toc-level-4,
  .toc-level-5,
  .toc-level-6 { padding-left: 3rem; opacity: 0.8; }
</style>
