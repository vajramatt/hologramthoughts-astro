---
interface Props {
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { headings } = Astro.props;
const showTOC = headings && headings.length > 1;
---

{showTOC && (
  <nav class="glass p-4 my-8 text-sm">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-2">Contents</p>
    <ul class="space-y-1">
      {headings.map((heading) => (
        <li class={`toc-level-${heading.depth}`}>
          <a href={`#${heading.slug}`} class="no-underline text-[var(--color-ink-soft)] hover:text-[var(--color-cyan)] transition-colors block py-0.5">{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-level-2 { padding-left: 0.75rem; }
  .toc-level-3 { padding-left: 1.5rem; }
  .toc-level-4,
  .toc-level-5,
  .toc-level-6 { padding-left: 2.25rem; opacity: 0.85; }
</style>
