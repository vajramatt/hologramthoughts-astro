---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  activePage: 'home' | 'archive' | 'categories' | 'search';
}

const { activePage } = Astro.props;
---

<header class="site-header">
  <div class="brand">
    <a href="/" aria-label="Hologram Thoughts — home">
      <span class="brand-mark" aria-hidden="true">☸</span>
      <span class="brand-name">Hologram Thoughts</span>
    </a>
    <p class="brand-tagline">ideas last forever</p>
  </div>

  <nav class="site-nav" aria-label="Primary">
    <a href="/archive"    class:list={[{ active: activePage === 'archive' }]}>archive</a>
    <a href="/categories" class:list={[{ active: activePage === 'categories' }]}>categories</a>
    <a href="/search"     class:list={[{ active: activePage === 'search' }]}>search</a>
    <a href="/rss.xml"    aria-label="RSS feed">feed</a>
    <ThemeToggle />
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 2rem 0 1.25rem;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }

  .brand a {
    text-decoration: none;
    color: var(--fg-bright);
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .brand a:hover { color: var(--accent); }

  .brand-mark {
    font-size: 1.1em;
    color: var(--accent);
    line-height: 1;
    position: relative;
    top: 0.05em;
  }

  .brand-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 30;
    font-weight: 500;
    font-size: 1.45rem;
    letter-spacing: -0.015em;
  }

  .brand-tagline {
    margin: 0.15rem 0 0;
    color: var(--muted);
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.35rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
  }

  .site-nav a {
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 150ms ease;
    letter-spacing: 0.01em;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--accent);
  }

  .site-nav a.active {
    font-style: italic;
  }

  @media (max-width: 42rem) {
    .site-header {
      padding: 1.5rem 0 1rem;
      gap: 1rem;
    }
    .brand-name { font-size: 1.25rem; }
    .site-nav { gap: 1rem; font-size: 0.85rem; }
  }
</style>
