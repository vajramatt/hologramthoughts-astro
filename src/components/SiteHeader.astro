---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  activePage: 'home' | 'archive' | 'categories' | 'search';
}

const { activePage } = Astro.props;
---

<header class="terminal-header">
  <div class="terminal-titlebar">
    <div class="titlebar-dharma">☸</div>
    <div class="titlebar-title">dharma://hologram.thoughts</div>
    <div class="titlebar-toggle">
      <ThemeToggle />
    </div>
  </div>
  <nav class="terminal-nav">
    <a href="/" class:list={[{ active: activePage === 'home' }]}>hologram-thoughts</a>
    <a href="/archive" class:list={[{ active: activePage === 'archive' }]}>archive</a>
    <a href="/categories" class:list={[{ active: activePage === 'categories' }]}>categories</a>
    <a href="/search" class:list={[{ active: activePage === 'search' }]}>search</a>
  </nav>
</header>

<style>
  .terminal-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--term-bg);
  }

  .terminal-titlebar {
    background: var(--term-titlebar-bg);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--term-border);
  }

  .titlebar-dharma {
    font-size: 18px;
    color: var(--term-accent);
    text-shadow: var(--term-glow);
    flex-shrink: 0;
    line-height: 1;
  }

  .titlebar-title {
    flex: 1;
    text-align: center;
    color: var(--term-muted);
    font-size: 13px;
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .titlebar-toggle {
    flex-shrink: 0;
  }

  .terminal-nav {
    padding: 12px 20px;
    border-bottom: 1px solid var(--term-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 24px;
    background: var(--term-bg);
  }

  .terminal-nav a {
    color: var(--term-fg-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .terminal-nav a::before {
    content: "→ ";
    color: var(--term-muted);
  }

  .terminal-nav a:hover,
  .terminal-nav a.active {
    color: var(--term-accent);
    text-shadow: var(--term-glow);
  }

  @media (max-width: 50rem) {
    .terminal-nav {
      padding: 10px 16px;
      gap: 0 16px;
    }

    .titlebar-title {
      font-size: 11px;
    }
  }
</style>
