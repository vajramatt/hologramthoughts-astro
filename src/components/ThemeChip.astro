---
interface Props { id: string; name: string; }
const { id, name } = Astro.props;
---
<button
  type="button"
  class="theme-chip inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium text-[var(--color-ink)] border border-[var(--color-border-strong)] transition-all duration-[var(--dur-med)] ease-[cubic-bezier(0.16,1,0.3,1)] hover:border-[var(--color-bioluminescent)] hover:text-[var(--color-bioluminescent)]"
  style="background: color-mix(in oklch, var(--color-spore) 8%, transparent); font-family: var(--font-ui);"
  data-theme={id}
  aria-label={`Explore theme: ${name}`}
>
  <svg width="8" height="8" viewBox="0 0 10 10" aria-hidden="true"><circle cx="5" cy="5" r="3" fill="currentColor" opacity="0.55"/></svg>
  <span>{name}</span>
</button>
