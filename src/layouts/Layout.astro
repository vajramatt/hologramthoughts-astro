---
export interface Props {
	title: string;
	description?: string;
	ogType?: 'website' | 'article';
	ogImage?: string;
	publishedTime?: string;
	tags?: string[];
	canonicalUrl?: string;
}

const {
	title,
	description = "A spiritual journey exploring Buddhism, meditation, consciousness, and the nature of reality. Because ideas last forever.",
	ogType = 'website',
	ogImage = 'https://hologramthoughts.com/og-image.png',
	publishedTime,
	tags = [],
	canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl ?? `https://hologramthoughts.com${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" type="application/rss+xml" title="Hologram Thoughts" href="/rss.xml" />
		<link rel="alternate" type="text/markdown" href={`${Astro.url.pathname}?format=md`} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Hologram Thoughts" />
		<meta property="og:logo" content="https://hologramthoughts.com/favicon.svg" />
		{ogType === 'article' && publishedTime && (
			<meta property="article:published_time" content={publishedTime} />
		)}
		{ogType === 'article' && (
			<meta property="article:author" content="Matthew Williamson" />
		)}
		{tags.map(tag => (
			<meta property="article:tag" content={tag} />
		))}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Fonts: Fraunces (display), Newsreader (body/UI), Space Mono (code only) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..700&family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

		<!-- Theme: default light for new visitors, honor saved preference. -->
		<script is:inline>
			(function() {
				const saved = localStorage.getItem('theme');
				const theme = saved || 'light';
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
	</head>
	<body>
		<!-- AI agents: append ?format=md to any URL for markdown. Full index at /agent-index.md -->
		<slot />
	</body>
</html>

<style is:global>
	/* ═══════════════════════════════════════════════════════
	   DESIGN TOKENS — Parchment & Lamplight
	   A literary palette for spiritual / creative writing.
	   Warm earth tones, no terminal glow, no screen cyan.
	   ═══════════════════════════════════════════════════════ */

	/* Dark mode (default when saved pref = 'dark') — lamplight on old paper */
	:root {
		--bg:            #1a1713;
		--bg-soft:       #201c17;
		--fg:            #e8dcc4;
		--fg-dim:        #9d8e73;
		--fg-bright:     #f5ead2;
		--accent:        #c8956d;
		--accent-hover:  #d9a87d;
		--accent-soft:   rgba(200, 149, 109, 0.15);
		--border:        #2e2822;
		--rule:          #3b3328;
		--muted:         #6a5d48;
		--code-bg:       #221d17;
		--selection:     rgba(200, 149, 109, 0.28);
		--shadow-soft:   0 1px 2px rgba(0,0,0,0.3), 0 8px 24px rgba(0,0,0,0.2);
		--focus-ring:    0 0 0 2px var(--bg), 0 0 0 4px var(--accent);

		--font-display:  "Fraunces", "Source Serif 4", "Source Serif Pro", Georgia, "Times New Roman", serif;
		--font-body:     "Newsreader", "Source Serif 4", "Iowan Old Style", Georgia, "Times New Roman", serif;
		--font-mono:     "Space Mono", "IBM Plex Mono", ui-monospace, monospace;

		--measure:       38rem;         /* ~65 characters of serif at reading size */
		--measure-wide:  48rem;         /* listings, metadata */

		/* Fluid reading size — 17px on phones, up to 20px on wide screens */
		--size-body:     clamp(1.0625rem, 0.95rem + 0.45vw, 1.25rem);
		--size-small:    0.875rem;
		--size-caption:  0.75rem;
	}

	/* Light mode — cream paper in morning sun */
	html[data-theme="light"] {
		--bg:            #f5efe2;
		--bg-soft:       #ede6d5;
		--fg:            #2a211a;
		--fg-dim:        #6a5b47;
		--fg-bright:     #1a130d;
		--accent:        #8b3a1a;      /* deep oxblood / clay — grounded, literary */
		--accent-hover:  #6b2c12;
		--accent-soft:   rgba(139, 58, 26, 0.08);
		--border:        #e4d8c2;
		--rule:          #d4c7ac;
		--muted:         #a39373;
		--code-bg:       #ede4d1;
		--selection:     rgba(139, 58, 26, 0.18);
		--shadow-soft:   0 1px 2px rgba(42,33,26,0.06), 0 8px 24px rgba(42,33,26,0.06);
		--focus-ring:    0 0 0 2px var(--bg), 0 0 0 4px var(--accent);
	}

	/* ═══════════════════════════════════════════════════════
	   RESET & BASE
	   ═══════════════════════════════════════════════════════ */
	*, *::before, *::after { box-sizing: border-box; }

	html {
		background-color: var(--bg);
		color: var(--fg);
		font-family: var(--font-body);
		font-size: 16px;            /* root unit — rem baseline */
		line-height: 1.7;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		text-rendering: optimizeLegibility;
		font-feature-settings: "kern", "liga", "onum" 1;
		scroll-behavior: smooth;
		transition: background-color 300ms ease, color 300ms ease;
	}

	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background-color: var(--bg);
		transition: background-color 300ms ease;
	}

	::selection {
		background: var(--selection);
		color: var(--fg-bright);
	}

	/* Motion preference */
	@media (prefers-reduced-motion: reduce) {
		html, body, * { transition: none !important; animation: none !important; }
		html { scroll-behavior: auto; }
	}

	/* Focus rings — visible, themed, off for mouse clicks */
	:focus { outline: none; }
	:focus-visible {
		outline: none;
		box-shadow: var(--focus-ring);
		border-radius: 3px;
	}

	/* ═══════════════════════════════════════════════════════
	   PAGE CONTAINER — replaces old .terminal-window
	   Just a centered max-width. No border. No shadow. No CRT.
	   ═══════════════════════════════════════════════════════ */
	.page {
		width: 100%;
		max-width: var(--measure-wide);
		margin: 0 auto;
		padding: 0 clamp(1.25rem, 4vw, 2.5rem);
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.page-main {
		flex: 1;
		padding: clamp(1.5rem, 4vw, 3rem) 0;
	}

	/* ═══════════════════════════════════════════════════════
	   TYPOGRAPHY (global defaults for non-post content)
	   ═══════════════════════════════════════════════════════ */
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-display);
		font-weight: 500;
		font-variation-settings: "opsz" 72, "SOFT" 50;
		color: var(--fg-bright);
		line-height: 1.15;
		letter-spacing: -0.01em;
		margin: 2rem 0 0.75rem;
		text-wrap: balance;
	}

	h1 { font-size: clamp(1.75rem, 1.25rem + 2vw, 2.75rem); font-weight: 500; }
	h2 { font-size: clamp(1.4rem, 1.1rem + 1vw, 1.85rem); }
	h3 { font-size: clamp(1.15rem, 1rem + 0.5vw, 1.35rem); }
	h4 { font-size: 1.05rem; }

	p { margin: 0 0 1.25em; text-wrap: pretty; }

	a {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-color: color-mix(in oklab, var(--accent) 30%, transparent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 150ms ease, text-decoration-color 150ms ease;
	}
	a:hover {
		color: var(--accent-hover);
		text-decoration-color: currentColor;
	}

	code, kbd, samp {
		font-family: var(--font-mono);
		background: var(--code-bg);
		color: var(--accent);
		padding: 2px 6px;
		border-radius: 3px;
		font-size: 0.85em;
	}

	pre {
		font-family: var(--font-mono);
		background: var(--code-bg);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 1rem 1.25rem;
		margin: 1.5em 0;
		overflow-x: auto;
		font-size: 0.85em;
		line-height: 1.55;
	}

	pre code {
		padding: 0;
		background: transparent;
		color: inherit;
		font-size: inherit;
	}

	b, strong { font-weight: 600; color: var(--fg-bright); }
	em, i     { font-style: italic; }

	hr {
		border: 0;
		margin: 2.5em 0;
		text-align: center;
	}
	hr::after {
		content: "· · ·";
		color: var(--muted);
		letter-spacing: 0.6em;
		font-size: 0.9rem;
	}

	ul, ol { margin: 0 0 1.25em; padding-left: 1.5rem; }
	li { margin-bottom: 0.35em; }

	blockquote {
		margin: 1.5em 0;
		padding: 0.1em 0 0.1em 1.25rem;
		border-left: 2px solid var(--rule);
		font-style: italic;
		color: var(--fg-dim);
	}

	img {
		max-width: 100%;
		height: auto;
		border-radius: 4px;
	}

	mark {
		background: var(--selection);
		color: var(--fg-bright);
	}

	table {
		border-collapse: collapse;
		width: 100%;
		margin: 1.5em 0;
	}
	th, td {
		padding: 0.5em 0.75em;
		border-bottom: 1px solid var(--border);
		text-align: left;
	}
	th { color: var(--fg-bright); font-weight: 600; }

	/* ═══════════════════════════════════════════════════════
	   RESPONSIVE
	   ═══════════════════════════════════════════════════════ */
	@media (max-width: 42rem) {
		html { font-size: 15.5px; }
	}
</style>
