---
// Legacy layout — use src/pages/blog/[slug].astro for new posts.
import Layout from './Layout.astro';
import ThemeChipStrip from '../components/ThemeChipStrip.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  frontmatter: any;
  themeIds?: string[];
  related?: import('../lib/themes').RelatedPost[];
}

const { frontmatter, themeIds = [], related = [] } = Astro.props as Props;
const dateStr = frontmatter.pubDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});
---

<Layout title={`${frontmatter.title} — Hologram Thoughts`}>
  <article>
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] mb-3">
        <time datetime={frontmatter.pubDate?.toISOString()}>{dateStr}</time>
      </p>
      <h1 class="text-4xl md:text-5xl tracking-tight leading-[1.1] text-[var(--color-ink)]" style="font-family: var(--font-display);">{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="text-lg text-[var(--color-ink-soft)] mt-4 leading-relaxed">{frontmatter.description}</p>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <ThemeChipStrip themeIds={themeIds} />
    <RelatedPosts related={related} />
  </article>
</Layout>

<style>
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink);
  }

  .post-content :global(p) { margin-bottom: 1.5rem; }
  .post-content :global(a) {
    color: var(--color-amber-bright);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .post-content :global(a:hover) { color: var(--color-cyan); }
  .post-content :global(strong) { font-weight: 600; }
</style>
