---
// Legacy layout — use src/pages/blog/[slug].astro for new posts.
import Layout from './Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} - Hologram Thoughts`}>
  <SiteHeader activePage="home" />

  <main>
    <div class="terminal-main">
      <div class="shell-session">
        <div class="shell-line">
          <span class="ps1">
            <span class="ps1-user">matt@hologramthoughts</span><span class="ps1-sep">:</span><span class="ps1-dir">~/posts</span><span class="ps1-dollar">$</span>
          </span>
          <span class="shell-cmd">cat ./post.md</span>
        </div>

        <div class="shell-output">
          <article class="post">
            <header class="post-header">
              <h1>{frontmatter.title}</h1>
              <p class="post-meta">
                <time datetime={frontmatter.pubDate?.toISOString()}>
                  {frontmatter.pubDate?.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
              </p>
            </header>
            <div class="post-content">
              <slot />
            </div>
          </article>
        </div>
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  main { margin: 0; padding: 0; }

  .shell-session { font-size: 14px; line-height: 1.5; }
  .shell-line { margin-bottom: 0.5rem; }

  .ps1 { font-weight: 700; margin-right: 0.5em; }
  .ps1-user   { color: var(--term-green); }
  .ps1-sep    { color: var(--term-fg); }
  .ps1-dir    { color: #9b6bdf; }
  .ps1-dollar { color: var(--term-fg); margin-left: 0.1em; }
  .shell-cmd  { color: var(--term-fg); }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--term-border);
  }

  .post-header h1 {
    color: var(--term-accent);
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }

  .post-meta {
    color: var(--term-muted);
    font-size: 13px;
    margin: 0;
  }

  .post-content {
    font-size: 15px;
    line-height: 1.75;
    color: var(--term-fg);
  }

  .post-content :global(p) { margin-bottom: 1.5rem; }
  .post-content :global(a) { color: var(--term-accent); text-decoration: none; }
  .post-content :global(a:hover) { color: var(--term-accent-hover); text-decoration: underline; }
  .post-content :global(strong) { color: var(--term-fg-bright); font-weight: 600; }
</style>
